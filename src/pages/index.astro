---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: "How is a fractional SEO consultant different from an agency?",
    answer: "A fractional SEO consultant embeds directly with your team, giving you senior-level expertise without the agency overhead, long-term contracts, or account manager layers. You get one expert fully focused on your business — not a rotating team juggling 50+ accounts."
  },
  {
    question: "How much does fractional SEO consulting cost?",
    answer: "Fractional SEO engagements typically range from a focused project to an ongoing monthly retainer. This model is significantly more cost-effective than hiring a full-time SEO director or a full-service agency, while delivering the same level of strategic depth. Reach out for a tailored proposal."
  },
  {
    question: "How quickly will I see results from SEO?",
    answer: "Most businesses see meaningful improvements in organic traffic within 3–6 months, with compounding results over 12+ months. Technical fixes and quick wins can show results faster, while content and link building strategies build lasting authority over time."
  },
  {
    question: "What types of businesses do you work with?",
    answer: "Hristijan works primarily with SaaS companies, e-commerce brands, publishing and media businesses, and enterprise teams. The fractional model is ideal for growing companies that need senior SEO strategy without the cost of a full-time hire."
  },
  {
    question: "What does 'fractional' actually mean?",
    answer: "Fractional means you get a senior SEO consultant working as part of your team — without the full-time salary, benefits, or overhead. You pay for the expertise and time you actually need, making it a smart, scalable model for businesses at any growth stage."
  }
];

// Real testimonials — rotated through automatically, 3 visible at a time
const testimonials = [
  {
    quote: "Increased our visibility, traffic, and search rankings through a smart SEO + social strategy.",
    name: "Amanda Herzog",
    role: "Amanda Herzog",
    initials: "AH",
  },
  {
    quote: "Handled a complex 3-to-1 domain migration flawlessly while preserving our SEO performance.",
    name: "Joseph Kuehn",
    role: "IFA Tactical",
    initials: "JK",
  },
  {
    quote: "Fast, professional, and highly efficient. Delivered exactly what we needed.",
    name: "Bruno Mirchevski",
    role: "HostAdvice",
    initials: "BM",
  },
  {
    quote: "Clear communication, strong execution, and reliable outreach performance.",
    name: "Bo Sasson",
    role: "Verpex",
    initials: "BS",
  },
  {
    quote: "Hristijan demonstrated a strong, self-sufficient work ethic and delivered excellent results. He was a valuable addition to the team from day one.",
    name: "David Fleisch",
    role: "Veeva Systems",
    initials: "DF",
  },
  {
    quote: "An outstanding professional — consistently delivered high-quality results, improved processes, and someone you can rely on to get things done.",
    name: "Kristija Gjorgjoiski",
    role: "Webtec",
    initials: "KG",
  },
];
---

<BaseLayout
  title="Fractional SEO Consultant | Hristijan Najcheski"
  description="Hire a Fractional SEO Consultant with 8+ years of experience. Senior-level SEO strategy for SaaS, e-commerce, and enterprise — without the full-time cost."
  schemaType="person"
  faqItems={faqItems}
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-grid"></div>
    </div>
    <div class="container">
      <div class="hero-layout">
        <div class="hero-content">
          <span class="hero-badge">Available for Fractional Engagements</span>
          <h1>
            Senior SEO Strategy,<br />
            <span class="text-gradient">Without the Full-Time Hire</span>
          </h1>
          <p class="hero-description">
            Enterprise-level SEO expertise embedded directly in your team.
            Data-driven, results-focused, and built for sustainable organic growth —
            without the agency overhead.
          </p>
          <div class="hero-actions">
            <a href="/contact/" class="btn btn-primary btn-lg">Book a Free Strategy Call</a>
            <a href="/services/" class="btn btn-secondary btn-lg">View Services →</a>
          </div>
          <div class="hero-stats">
            <div>
              <div class="stat-value">50+</div>
              <div class="stat-label">Projects Delivered</div>
            </div>
            <div>
              <div class="stat-value">3x</div>
              <div class="stat-label">Avg. Traffic Growth</div>
            </div>
            <div>
              <div class="stat-value">8+</div>
              <div class="stat-label">Years Experience</div>
            </div>
          </div>
        </div>
        <div class="hero-image-col">
          <div class="hero-image-wrap">
            <img
              src="/images/author-avatar.webp"
              alt="Hristijan Najcheski — Fractional SEO Consultant"
              width="420"
              height="420"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero-layout {
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: var(--space-16);
      align-items: center;
      width: 100%;
    }

    .hero-image-col {
      display: flex;
      justify-content: center;
      align-items: center;
      animation: fadeInUp 0.6s ease-out 0.5s backwards;
    }

    .hero-image-wrap {
      position: relative;
      width: 380px;
      height: 380px;
      border-radius: 50%;
      overflow: hidden;
      border: 3px solid var(--color-border);
      box-shadow: var(--shadow-xl), 0 0 60px rgba(37, 99, 235, 0.1);
    }

    .hero-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 1024px) {
      .hero-layout {
        grid-template-columns: 1fr 320px;
        gap: var(--space-10);
      }
      .hero-image-wrap {
        width: 300px;
        height: 300px;
      }
    }

    @media (max-width: 768px) {
      .hero-layout {
        grid-template-columns: 1fr;
      }
      .hero-image-col {
        display: none;
      }
    }

    /* GEO Definition */
    .section-geo { padding-top: 0; padding-bottom: var(--space-6); }
    .geo-definition {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-accent-blue);
      border-left: 4px solid var(--color-accent-blue);
      border-radius: var(--radius-xl);
      padding: var(--space-6) var(--space-8);
    }
    .geo-label {
      font-size: var(--text-xs);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-accent-blue);
      margin-bottom: var(--space-3);
    }
    .geo-definition p { color: var(--color-text-secondary); line-height: 1.8; }
    .geo-links {
      display: flex;
      gap: var(--space-6);
      margin-top: var(--space-4);
      flex-wrap: wrap;
    }
    .geo-links a {
      font-size: var(--text-sm);
      font-weight: 600;
      color: var(--color-accent-blue);
    }

    /* How It Works */
    .how-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
      margin-top: var(--space-10);
    }
    .how-step {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
    }
    .how-number {
      font-family: var(--font-heading);
      font-size: var(--text-4xl);
      font-weight: 900;
      color: var(--color-accent-blue);
      opacity: 0.3;
      line-height: 1;
      margin-bottom: var(--space-3);
    }
    .how-step h3 {
      font-family: var(--font-heading);
      font-size: var(--text-lg);
      font-weight: 700;
      color: var(--color-text-primary);
      margin-bottom: var(--space-2);
    }

    /* Case Studies */
    .case-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
      margin-top: var(--space-10);
    }
    .case-card {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-7);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .case-industry {
      font-size: var(--text-xs);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-accent-blue);
    }
    .case-metric {
      font-family: var(--font-heading);
      font-size: var(--text-5xl);
      font-weight: 900;
      color: var(--color-text-primary);
      line-height: 1;
    }
    .case-metric-label {
      font-size: var(--text-sm);
      color: var(--color-text-muted);
      font-weight: 600;
      margin-top: calc(var(--space-1) * -1);
    }
    .case-desc {
      font-size: var(--text-sm);
      color: var(--color-text-secondary);
      line-height: 1.7;
      flex: 1;
    }
    .case-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-top: var(--space-2);
    }
    .case-tags span {
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--color-text-muted);
      background: var(--icon-bg);
      border: 1px solid var(--color-border);
      border-radius: 999px;
      padding: 3px 10px;
    }

    @media (max-width: 1024px) {
      .how-grid { grid-template-columns: repeat(2, 1fr); }
      .case-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
      .how-grid { grid-template-columns: 1fr; }
    }

    /* Who I Work With */
    .icp-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
      margin-top: var(--space-10);
    }

    .icp-card {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
      transition: border-color var(--transition-fast), transform var(--transition-fast);
    }

    .icp-card:hover {
      border-color: var(--color-accent-blue);
      transform: translateY(-2px);
    }

    .icp-icon {
      font-size: 2rem;
      margin-bottom: var(--space-3);
    }

    .icp-title {
      font-family: var(--font-heading);
      font-size: var(--text-lg);
      font-weight: 700;
      color: var(--color-text-primary);
      margin-bottom: var(--space-2);
    }

    .icp-desc {
      font-size: var(--text-sm);
      color: var(--color-text-muted);
      line-height: 1.6;
    }

    @media (max-width: 1024px) {
      .icp-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
      .icp-grid { grid-template-columns: 1fr; }
    }

    /* FAQ */
    .faq-list {
      margin-top: var(--space-10);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    .faq-item {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      overflow: hidden;
    }

    .faq-question {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      padding: var(--space-5) var(--space-6);
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      font-family: var(--font-heading);
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--color-text-primary);
    }

    .faq-chevron {
      flex-shrink: 0;
      transition: transform 0.25s ease;
      color: var(--color-text-muted);
    }

    .faq-item.open .faq-chevron {
      transform: rotate(180deg);
    }

    .faq-answer {
      display: none;
      padding: 0 var(--space-6) var(--space-5);
      font-size: var(--text-base);
      color: var(--color-text-secondary);
      line-height: 1.7;
    }

    .faq-item.open .faq-answer {
      display: block;
    }
  </style>

  <!-- GEO Definition Block -->
  <section class="section section-geo">
    <div class="container">
      <div class="geo-definition">
        <div class="geo-label">What is a Fractional SEO Consultant?</div>
        <p>A <strong>fractional SEO consultant</strong> is a senior-level SEO expert who works with businesses on a part-time or retainer basis, acting as a strategic leader without the full-time cost. Unlike freelancers who execute tasks, a fractional consultant owns the SEO roadmap, integrates with the team, and delivers the same strategic depth as a VP of SEO — at a fraction of the investment. The model is particularly well-suited for SaaS, e-commerce, and enterprise companies that need senior SEO expertise but aren't at the stage to justify a full-time hire.</p>
        <div class="geo-links">
          <a href="/about/">Learn how the model works →</a>
          <a href="/pricing/">View engagement options →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section" id="services-overview">
    <div class="container">
      <span class="section-label">What I Do</span>
      <h2 class="section-title">SEO services that <span class="text-gradient">drive results</span></h2>
      <p class="section-subtitle">
        Comprehensive SEO consulting tailored to your business goals and growth stage.
      </p>

      <div class="services-grid" style="margin-top: var(--space-10);">
        <div class="card">
          <div class="card-icon">⚙️</div>
          <h3 class="card-title">Technical SEO</h3>
          <p class="card-text">
            Site architecture, Core Web Vitals, crawlability, indexation, and
            technical foundation that search engines love.
          </p>
        </div>

        <div class="card">
          <div class="card-icon">📝</div>
          <h3 class="card-title">Content Strategy</h3>
          <p class="card-text">
            Keyword research, topic clusters, content calendars, and strategic
            content that ranks and converts.
          </p>
        </div>

        <div class="card">
          <div class="card-icon">🔗</div>
          <h3 class="card-title">Link Building</h3>
          <p class="card-text">
            High-quality, white-hat link acquisition strategies that build
            domain authority and trust signals.
          </p>
        </div>

        <div class="card">
          <div class="card-icon">🔍</div>
          <h3 class="card-title">SEO Audits</h3>
          <p class="card-text">
            Comprehensive technical and content audits that uncover opportunities
            and eliminate what's holding you back.
          </p>
        </div>

        <div class="card">
          <div class="card-icon">📊</div>
          <h3 class="card-title">Analytics & Reporting</h3>
          <p class="card-text">
            Custom dashboards, KPI tracking, and actionable reporting that
            connects SEO performance to revenue.
          </p>
        </div>

        <div class="card">
          <div class="card-icon">🌍</div>
          <h3 class="card-title">Local & International SEO</h3>
          <p class="card-text">
            Multi-location and multi-language SEO strategies for businesses
            targeting local or global markets.
          </p>
        </div>
      </div>

      <div style="text-align: center; margin-top: var(--space-10);">
        <a href="/services/" class="btn btn-secondary btn-lg">View All Services →</a>
      </div>
    </div>
  </section>

  <!-- Who I Work With -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <span class="section-label">Who I Work With</span>
      <h2 class="section-title">Built for <span class="text-gradient">growth-focused</span> teams</h2>
      <p class="section-subtitle">
        The fractional model works best when you need senior strategy without the full-time overhead.
        Here's who I typically work with:
      </p>
      <div class="icp-grid">
        <div class="icp-card">
          <div class="icp-icon">🚀</div>
          <div class="icp-title">SaaS Companies</div>
          <p class="icp-desc">Growing platforms that need sustainable organic acquisition to reduce CAC and compound over time.</p>
        </div>
        <div class="icp-card">
          <div class="icp-icon">🛒</div>
          <div class="icp-title">E-commerce Brands</div>
          <p class="icp-desc">Online stores ready to reduce paid spend by building strong organic product and category page rankings.</p>
        </div>
        <div class="icp-card">
          <div class="icp-icon">📰</div>
          <div class="icp-title">Publishing & Media</div>
          <p class="icp-desc">Content-driven businesses scaling organic traffic, ad revenue, and audience reach through search.</p>
        </div>
        <div class="icp-card">
          <div class="icp-icon">🏢</div>
          <div class="icp-title">Enterprise Teams</div>
          <p class="icp-desc">Large organisations that need a senior SEO strategist to lead, audit, and align cross-functional teams.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Snippet -->
  <section class="section">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <span class="section-label">About Me</span>
          <h2>A consultant, not an agency</h2>
          <p>
            I'm Hristijan Najcheski — a fractional SEO consultant who embeds
            directly with your team. Unlike agencies that spread thin across
            dozens of accounts, I bring focused, senior-level expertise to every
            engagement.
          </p>
          <p>
            With over 8 years of experience across SaaS, e-commerce, publishing,
            and enterprise, I've helped businesses of all sizes unlock their
            organic growth potential through strategic, data-driven SEO.
          </p>
          <a href="/about/" class="btn btn-secondary" style="margin-top: var(--space-4);">
            Learn More About Me →
          </a>
        </div>
        <div class="about-highlights">
          <div class="highlight-card">
            <div class="highlight-value">50+</div>
            <div class="highlight-label">Projects Completed</div>
          </div>
          <div class="highlight-card">
            <div class="highlight-value">8+</div>
            <div class="highlight-label">Years in SEO</div>
          </div>
          <div class="highlight-card">
            <div class="highlight-value">3x</div>
            <div class="highlight-label">Avg. Traffic Increase</div>
          </div>
          <div class="highlight-card">
            <div class="highlight-value">100%</div>
            <div class="highlight-label">Client Retention</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container">
      <span class="section-label">The Process</span>
      <h2 class="section-title">How we <span class="text-gradient">work together</span></h2>
      <p class="section-subtitle">Simple, transparent, and built around your goals from day one.</p>
      <div class="how-grid">
        <div class="how-step">
          <div class="how-number">01</div>
          <h3>Free Strategy Call</h3>
          <p class="card-text">30 minutes to understand your business, goals, and current SEO situation. No pitch — just an honest conversation about whether I can help.</p>
        </div>
        <div class="how-step">
          <div class="how-number">02</div>
          <h3>Scoped Proposal</h3>
          <p class="card-text">A clear proposal with the engagement model, scope, deliverables, and investment — written specifically for your situation, not a template.</p>
        </div>
        <div class="how-step">
          <div class="how-number">03</div>
          <h3>Discovery & Audit</h3>
          <p class="card-text">Every engagement starts with a thorough audit of your SEO landscape so the strategy is grounded in real data, not assumptions.</p>
        </div>
        <div class="how-step">
          <div class="how-number">04</div>
          <h3>Execution & Results</h3>
          <p class="card-text">We build, optimise, and iterate together. Regular reporting, clear priorities, and a consultant as invested in results as you are.</p>
        </div>
      </div>
      <div style="text-align: center; margin-top: var(--space-8);">
        <a href="/pricing/" class="btn btn-secondary">See Engagement Models →</a>
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <span class="section-label">Results</span>
      <h2 class="section-title">Real outcomes, <span class="text-gradient-orange">real numbers</span></h2>
      <p class="section-subtitle">A sample of what's possible when SEO strategy is done right.</p>
      <div class="case-grid">
        <div class="case-card">
          <div class="case-industry">SaaS</div>
          <div class="case-metric">+220%</div>
          <div class="case-metric-label">Organic traffic in 6 months</div>
          <p class="case-desc">Rebuilt site architecture, fixed crawl budget waste, and launched a topic cluster strategy targeting bottom-of-funnel SaaS keywords. CAC from organic dropped 35%.</p>
          <div class="case-tags">
            <span>Technical SEO</span>
            <span>Content Strategy</span>
          </div>
        </div>
        <div class="case-card">
          <div class="case-industry">E-commerce</div>
          <div class="case-metric">+$180K</div>
          <div class="case-metric-label">Organic revenue in 4 months</div>
          <p class="case-desc">Optimised 400+ product and category pages, implemented structured data, and fixed Core Web Vitals. Reduced reliance on paid ads by building strong organic category rankings.</p>
          <div class="case-tags">
            <span>On-Page SEO</span>
            <span>Schema Markup</span>
          </div>
        </div>
        <div class="case-card">
          <div class="case-industry">Publishing</div>
          <div class="case-metric">3x</div>
          <div class="case-metric-label">Organic sessions in 8 months</div>
          <p class="case-desc">Executed a full content audit, pruned underperforming pages, and launched a programmatic SEO strategy. Secured #1 rankings for 50+ high-volume industry keywords.</p>
          <div class="case-tags">
            <span>Content Audit</span>
            <span>Programmatic SEO</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <span class="section-label">Testimonials</span>
      <h2 class="section-title">What clients <span class="text-gradient-orange">say about me</span></h2>
      <p class="section-subtitle">
        Results speak louder than words — but kind words help too.
      </p>

      <div class="testimonials-rotator" id="testimonialsRotator" data-count={testimonials.length}>
        <div class="testimonials-grid">
          {testimonials.map((t, i) => (
            <div class={`testimonial-card${i < 3 ? ' is-active' : ''}`} data-index={i}>
              <div class="testimonial-stars">★★★★★</div>
              <p class="testimonial-text">"{t.quote}"</p>
              <div class="testimonial-author">
                <div class="testimonial-avatar">{t.initials}</div>
                <div>
                  <div class="testimonial-name">{t.name}</div>
                  <div class="testimonial-role">{t.role}</div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="testimonials-dots" id="testimonialsDots">
          {Array.from({ length: Math.ceil(testimonials.length / 3) }).map((_, i) => (
            <button class={`testimonials-dot${i === 0 ? ' is-active' : ''}`} data-page={i} aria-label={`Show testimonials page ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </div>

    <style>
      .testimonials-rotator {
        position: relative;
      }
      .testimonials-rotator .testimonials-grid > .testimonial-card {
        display: none;
        flex-direction: column;
        animation: testimonialFade 0.5s ease;
      }
      .testimonials-rotator .testimonials-grid > .testimonial-card.is-active {
        display: flex;
      }
      .testimonials-rotator .testimonial-text {
        flex-grow: 1;
      }
      @keyframes testimonialFade {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .testimonials-dots {
        display: flex;
        justify-content: center;
        gap: var(--space-3);
        margin-top: var(--space-6);
      }
      .testimonials-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: none;
        background: var(--color-border);
        cursor: pointer;
        padding: 0;
        transition: background 200ms ease, transform 200ms ease;
      }
      .testimonials-dot:hover {
        background: var(--color-text-muted);
      }
      .testimonials-dot.is-active {
        background: var(--color-accent-blue);
        transform: scale(1.25);
      }
    </style>

    <script>
      function initTestimonialsRotator() {
        const rotator = document.getElementById('testimonialsRotator');
        if (!rotator) return;

        const total = parseInt(rotator.dataset.count || '0', 10);
        const perPage = 3;
        const pageCount = Math.ceil(total / perPage);
        if (pageCount <= 1) return;

        const cards = rotator.querySelectorAll<HTMLElement>('.testimonial-card');
        const dots = rotator.querySelectorAll<HTMLElement>('.testimonials-dot');
        let currentPage = 0;
        let timer: number | undefined;

        function showPage(page: number) {
          currentPage = page;
          const start = page * perPage;
          const end = start + perPage;
          cards.forEach((c, i) => c.classList.toggle('is-active', i >= start && i < end));
          dots.forEach((d, i) => d.classList.toggle('is-active', i === page));
        }

        function next() {
          showPage((currentPage + 1) % pageCount);
        }

        function startTimer() {
          stopTimer();
          timer = window.setInterval(next, 6000);
        }
        function stopTimer() {
          if (timer) { clearInterval(timer); timer = undefined; }
        }

        dots.forEach((d) => {
          d.addEventListener('click', () => {
            const p = parseInt((d as HTMLElement).dataset.page || '0', 10);
            showPage(p);
            startTimer();
          });
        });

        rotator.addEventListener('mouseenter', stopTimer);
        rotator.addEventListener('mouseleave', startTimer);

        startTimer();
      }

      initTestimonialsRotator();
      document.addEventListener('astro:after-swap', initTestimonialsRotator);
    </script>
  </section>

  <!-- FAQ Section -->
  <section class="section">
    <div class="container">
      <span class="section-label">FAQ</span>
      <h2 class="section-title">Common <span class="text-gradient">questions</span></h2>
      <p class="section-subtitle">
        Everything you need to know before reaching out.
      </p>

      <div class="faq-list">
        {faqItems.map((item, i) => (
          <div class="faq-item" id={`faq-${i}`}>
            <button class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
              {item.question}
              <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="faq-answer" id={`faq-answer-${i}`}>
              {item.answer}
            </div>
          </div>
        ))}
      </div>

      <div style="text-align: center; margin-top: var(--space-8);">
        <a href="/contact/" class="btn btn-secondary">Still have questions? Get in touch →</a>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item') as HTMLElement;
        const isOpen = item.classList.contains('open');
        // Close all
        document.querySelectorAll('.faq-item').forEach((el) => {
          el.classList.remove('open');
          el.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
        });
        // Toggle clicked
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Ready to <span class="text-gradient-orange">grow organically</span>?</h2>
        <p>
          Let's discuss how a fractional SEO consultant can help your
          business reach its full potential in search.
        </p>
        <a href="/contact/" class="btn btn-orange btn-lg">Book a Free Strategy Call →</a>
      </div>
    </div>
  </section>
</BaseLayout>
