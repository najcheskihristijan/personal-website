---
import BaseLayout from '../../layouts/BaseLayout.astro';

const expertise = [
  'Technical SEO', 'Content Strategy', 'Link Building', 'SEO Audits',
  'Analytics & Reporting', 'Local SEO', 'E-Commerce SEO', 'Keyword Research',
  'On-Page SEO', 'Off-Page SEO', 'Site Architecture', 'Core Web Vitals',
];

const articles = [
  {
    slug: 'why-fractional-seo',
    title: 'Why Fractional SEO Consulting Is the Future for Growing Businesses',
    description: 'Discover why more businesses are choosing fractional SEO consultants over traditional agencies.',
    date: '2026-02-15',
    tag: 'Strategy',
    readTime: '6 min read',
  },
  {
    slug: 'technical-seo-checklist-2026',
    title: 'The Ultimate Technical SEO Checklist for 2026',
    description: 'A comprehensive technical SEO checklist covering Core Web Vitals, crawlability, and structured data.',
    date: '2026-02-10',
    tag: 'Technical SEO',
    readTime: '8 min read',
  },
  {
    slug: 'content-strategy-eeat',
    title: 'How to Build E-E-A-T Into Your Content Strategy',
    description: 'Learn how to demonstrate Experience, Expertise, Authoritativeness, and Trustworthiness.',
    date: '2026-02-05',
    tag: 'Content',
    readTime: '5 min read',
  },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Hristijan Najcheski — Author | Fractional SEO Consultant"
  description="Learn about Hristijan Najcheski, a Fractional SEO Consultant with 8+ years of experience helping businesses grow through data-driven SEO strategies."
  schemaType="person"
>
  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <span class="section-label">Author</span>
        <h1>Hristijan <span class="text-gradient">Najcheski</span></h1>
        <p>Fractional SEO Consultant helping businesses dominate search.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="author-profile">
        <div class="author-avatar">
          <img src="https://www.gravatar.com/avatar/7be017822cfe92e132a03733f068aba4?s=400" alt="Hristijan Najcheski — Fractional SEO Consultant" width="200" height="200" loading="lazy" />
        </div>
        <div class="author-bio">
          <h2>Hristijan Najcheski</h2>
          <div class="author-title">Fractional SEO Consultant</div>
          <p>
            I'm a fractional SEO consultant who embeds directly with your team to
            deliver enterprise-level search strategies. With 8+ years of experience
            across SaaS, e-commerce, publishing, and enterprise, I help businesses
            unlock their organic growth potential through strategic, data-driven SEO.
          </p>
          <p>
            Unlike agencies that spread thin across dozens of accounts, I bring
            focused, senior-level expertise to every engagement. My approach combines
            deep technical knowledge with strategic thinking to build sustainable
            organic growth — not just short-term wins.
          </p>
          <p>
            When I'm not optimizing websites, you can find me sharing SEO insights
            on my <a href="/blog/" style="color: var(--color-accent-blue);">blog</a>,
            speaking at industry events, or mentoring the next generation of SEO
            professionals.
          </p>

          <div class="author-social-links">
            <a href="https://www.linkedin.com/in/najcheski/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn" title="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://x.com/HNajcheski" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Twitter/X" title="Twitter/X">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://gravatar.com/najcheski" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GravatarProfile" title="Gravatar Profile">
               <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </a>
          </div>

          <div class="author-expertise">
            {expertise.map((skill) => (
              <span class="expertise-tag">{skill}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Articles by this author -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <span class="section-label">Published Articles</span>
      <h2 class="section-title">Articles by <span class="text-gradient">Hristijan</span></h2>
      <p class="section-subtitle">
        Sharing insights on SEO strategy, technical optimization, and content marketing.
      </p>

      <div class="blog-grid" style="margin-top: var(--space-10);">
        {articles.map((post) => (
          <a href={`/blog/${post.slug}/`} class="blog-card">
            <div class="blog-card-image">📄</div>
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="blog-card-tag">{post.tag}</span>
                <span>{formatDate(post.date)}</span>
                <span>·</span>
                <span>{post.readTime}</span>
              </div>
              <h3>{post.title}</h3>
              <p>{post.description}</p>
              <span class="blog-read-more">Read article →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Want to work <span class="text-gradient-orange">together</span>?</h2>
        <p>Let's discuss how I can help your business grow through organic search.</p>
        <a href="/contact/" class="btn btn-primary btn-lg">Get in Touch →</a>
      </div>
    </div>
  </section>
</BaseLayout>
