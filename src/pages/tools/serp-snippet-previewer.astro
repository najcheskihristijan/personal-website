  <script>
    // ============ State ============
    const PLACEHOLDER_TITLE = 'Your page title will appear here';
    const PLACEHOLDER_DESC = "Your meta description will appear here. Start typing in the form to see the preview update in real time.";

    // Tracked input ids
    const FIELDS = {
      fetchUrl: 'fetchUrl',
      keyword: 'keyword',
      title: 'title',
      url: 'url',
      description: 'description',
      ftDate: 'ftDate',
      dateChoice: 'dateChoice',
      ftRating: 'ftRating',
      ratingValue: 'ratingValue',
      reviewCount: 'reviewCount',
      ftSitelinks: 'ftSitelinks',
      sl1: 'sl1', sl2: 'sl2', sl3: 'sl3', sl4: 'sl4',
      ftFaq: 'ftFaq',
      faq1: 'faq1', faq2: 'faq2', faq3: 'faq3',
      ftImage: 'ftImage',
      imageUrl: 'imageUrl',
    } as const;

    const $ = (id: string) => document.getElementById(id)!;
    const $i = (id: string) => $(id) as HTMLInputElement;
    const $t = (id: string) => $(id) as HTMLTextAreaElement;
    const $s = (id: string) => $(id) as HTMLSelectElement;

    // ============ Pixel measurement ============
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d')!;
    function measure(text: string, font: string): number {
      ctx.font = font;
      return Math.round(ctx.measureText(text).width);
    }
    const TITLE_FONT = '400 20px arial, sans-serif';
    const DESC_FONT = '400 14px arial, sans-serif';
    const TITLE_MAX_PX = 600;
    const DESC_DESKTOP_MAX_PX = 920;

    // ============ Escape + bold ============
    function escapeHtml(s: string): string {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
    function escapeRegex(s: string): string {
      return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }
    function getKeywordTokens(): string[] {
      const k = $i(FIELDS.keyword).value || '';
      return k.split(/[,\n]+/).map(s => s.trim()).filter(s => s.length >= 2);
    }
    function safeUrl(raw: string): string {
      try {
        const u = new URL(raw);
        if (u.protocol === 'http:' || u.protocol === 'https:') return u.toString();
      } catch {
        // fall through
      }
      return '';
    }

    function boldKeyword(text: string): string {
      const tokens = getKeywordTokens();
      const esc = escapeHtml(text);
      if (!tokens.length) return esc;
      // Sort longest-first so 'seo tips' wins over 'seo' for overlapping matches.
      // Escape each token AFTER escapeHtml so '&' in keyword matches '&amp;' in text.
      const sorted = [...tokens].sort((a, b) => b.length - a.length);
      const re = new RegExp(`(${sorted.map(t => escapeRegex(escapeHtml(t))).join('|')})`, 'gi');
      return esc.replace(re, '<strong>$1</strong>');
    }

    // ============ Truncation simulation ============
    function truncateAtPixel(text: string, font: string, maxPx: number): string {
      if (!text) return text;
      if (measure(text, font) <= maxPx) return text;
      const words = text.split(/(\s+)/);
      let cur = '';
      for (const w of words) {
        const candidate = cur + w;
        if (measure(candidate + '…', font) > maxPx) break;
        cur = candidate;
      }
      if (cur.trim()) return cur.trimEnd() + '…';
      // No whole word fits (CJK with no whitespace, or single overflowing word).
      // Fall back to per-glyph truncation. Array.from handles surrogate pairs.
      const chars = Array.from(text);
      let out = '';
      for (const c of chars) {
        if (measure(out + c + '…', font) > maxPx) break;
        out += c;
      }
      return (out || chars[0] || '') + '…';
    }

    // ============ CTR analysis (client-side; mirrored to email payload) ============
    const POWER_WORDS = [
      'free','best','top','easy','simple','proven','ultimate',
      'guide','how to','why','now','today','fast','instant',
      'expert','complete','essential','powerful','effective',
      'new','updated','latest','step-by-step','checklist',
      'tips','tricks','secrets','mistakes','avoid','results','win',
    ];

    type CtrSignals = {
      hasNumber: boolean;
      hasYear: boolean;
      hasBracket: boolean;
      hasPowerWord: boolean;
      matchedPowerWords: string[];
      hasQuestion: boolean;
      titleHasKeyword: boolean;
      descHasKeyword: boolean;
      keywordEarlyInTitle: boolean;
      score: number;
      tips: string[];
    };

    // Word-boundary detector. Each power word is matched against the lowercased
    // title with \b on both sides so 'now' doesn't match 'snowboarding'. Multi-word
    // phrases ('how to', 'step-by-step') anchor on outer word boundaries only.
    function matchPowerWords(tLower: string): string[] {
      const out: string[] = [];
      for (const w of POWER_WORDS) {
        const re = new RegExp(`\\b${escapeRegex(w)}\\b`, 'i');
        if (re.test(tLower)) out.push(w);
