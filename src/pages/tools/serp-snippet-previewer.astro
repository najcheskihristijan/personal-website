---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free SERP Snippet Previewer | Google + AI Overview, Perplexity, ChatGPT | Hristijan Najcheski"
  description="Paste any URL — autofill the title and meta, preview how it renders in Google Desktop, Mobile, AI Overview, Perplexity, and ChatGPT. Live CTR score, rewrite-risk detector, rich-result simulators. Free, no signup."
>
  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <span class="section-label">SEO + AEO Tool</span>
        <h1>SERP Snippet <span class="text-gradient">Previewer</span></h1>
        <p>Paste any URL — it autofills the title and meta description. Preview how the page renders in Google Desktop, Mobile, <strong>AI Overview, Perplexity, and ChatGPT</strong>. Live CTR scoring, rewrite-risk detector, and rich-result simulators.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="tool-layout">
        <!-- =============== FORM =============== -->
        <aside class="tool-form">
          <!-- URL fetch -->
          <div class="form-field fetch-block">
            <label for="fetchUrl">Paste any URL — autofill the snippet</label>
            <div class="fetch-row">
              <input type="text" id="fetchUrl" placeholder="https://example.com/page" autocomplete="off" />
              <button type="button" id="fetchBtn" class="btn btn-orange">Fetch</button>
            </div>
            <div id="fetchStatus" class="fetch-status"></div>
          </div>

          <hr class="form-sep" />

          <!-- Target keyword -->
          <div class="form-field">
            <label for="keyword">Target keyword <span class="label-muted">(optional)</span></label>
            <input type="text" id="keyword" placeholder="e.g. fractional seo consultant" autocomplete="off" />
            <div class="hint">Used to bold matches and score CTR. Comma-separate multiple keywords.</div>
          </div>

          <!-- Title -->
          <div class="form-field">
            <label for="title">Page title</label>
            <input type="text" id="title" maxlength="120" placeholder="e.g. Free SERP Snippet Previewer — Hristijan Najcheski" />
            <div class="field-meter">
              <span id="titleChars">0</span> chars · <span id="titlePx">0</span>px
              <span id="titleStatus" class="status"></span>
            </div>
          </div>

          <!-- URL display -->
          <div class="form-field">
            <label for="url">URL shown in snippet</label>
            <input type="text" id="url" placeholder="https://hristijannajcheski.com/tools/serp-snippet-previewer/" />
          </div>

          <!-- Description -->
          <div class="form-field">
            <label for="description">Meta description</label>
            <textarea id="description" rows="4" maxlength="320" placeholder="Preview how your page will appear in Google's search results. Get pixel-width and character-count warnings for titles and meta descriptions."></textarea>
            <div class="field-meter">
              <span id="descChars">0</span> chars · <span id="descPx">0</span>px
              <span id="descStatus" class="status"></span>
            </div>
          </div>

          <!-- SERP features -->
          <details class="form-section" open>
            <summary>SERP rich-result features</summary>
            <div class="form-section-body">
              <div class="toggles">
                <label class="toggle"><input type="checkbox" id="ftDate" /> <span>Show date</span></label>
                <label class="toggle"><input type="checkbox" id="ftRating" /> <span>Star rating</span></label>
                <label class="toggle"><input type="checkbox" id="ftSitelinks" /> <span>Sitelinks</span></label>
                <label class="toggle"><input type="checkbox" id="ftFaq" /> <span>FAQ accordion</span></label>
                <label class="toggle"><input type="checkbox" id="ftImage" /> <span>Image thumbnail</span></label>
              </div>

              <div class="feature-detail" data-for="ftDate">
                <label class="sub-label">Date prefix</label>
                <select id="dateChoice">
                  <option value="today">Today</option>
                  <option value="2 days ago">2 days ago</option>
                  <option value="1 week ago">1 week ago</option>
                  <option value="1 month ago">1 month ago</option>
                </select>
              </div>

              <div class="feature-detail" data-for="ftRating">
                <div class="row-2">
                  <div>
                    <label class="sub-label">Rating</label>
                    <input type="number" id="ratingValue" min="0" max="5" step="0.1" value="4.7" />
                  </div>
                  <div>
                    <label class="sub-label">Review count</label>
                    <input type="number" id="reviewCount" min="0" value="328" />
                  </div>
                </div>
              </div>

              <div class="feature-detail" data-for="ftSitelinks">
                <label class="sub-label">Sitelinks (up to 4)</label>
                <input type="text" id="sl1" placeholder="Sitelink 1 — Pricing" />
                <input type="text" id="sl2" placeholder="Sitelink 2 — About" />
                <input type="text" id="sl3" placeholder="Sitelink 3 — Contact" />
                <input type="text" id="sl4" placeholder="Sitelink 4 — Blog" />
              </div>

              <div class="feature-detail" data-for="ftFaq">
                <label class="sub-label">FAQ questions (up to 3)</label>
                <input type="text" id="faq1" placeholder="How does X work?" />
                <input type="text" id="faq2" placeholder="What is Y?" />
                <input type="text" id="faq3" placeholder="Why should I use Z?" />
              </div>

              <div class="feature-detail" data-for="ftImage">
                <label class="sub-label">Image URL <span class="label-muted">(leave blank for placeholder)</span></label>
                <input type="text" id="imageUrl" placeholder="https://example.com/thumb.jpg" />
              </div>
            </div>
          </details>

          <hr class="form-sep" />

          <!-- Email gate -->
          <div class="email-gate">
            <h3>Get the full optimization report</h3>
            <p>I'll run a full snippet analysis <strong>plus an AEO audit</strong> of your URL and email a fix-list. Free.</p>
            <input type="email" id="leadEmail" placeholder="you@company.com" autocomplete="email" aria-label="Email address" />
            <input type="text" id="hp" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <button type="button" id="reportBtn" class="btn btn-orange btn-block">Email me the report →</button>
            <div id="leadStatus" class="lead-status"></div>
          </div>
        </aside>

        <!-- =============== PREVIEW =============== -->
        <div class="tool-preview">
          <div class="preview-tabs" role="tablist" aria-label="Preview surface">
            <button class="preview-tab active" data-view="desktop" type="button" role="tab" aria-selected="true" aria-controls="desktopPreview" id="tab-desktop">Google Desktop</button>
            <button class="preview-tab" data-view="mobile" type="button" role="tab" aria-selected="false" aria-controls="mobilePreview" id="tab-mobile">Google Mobile</button>
            <button class="preview-tab" data-view="aiOverview" type="button" role="tab" aria-selected="false" aria-controls="aiOverviewPreview" id="tab-aiOverview">AI Overview</button>
            <button class="preview-tab" data-view="perplexity" type="button" role="tab" aria-selected="false" aria-controls="perplexityPreview" id="tab-perplexity">Perplexity</button>
            <button class="preview-tab" data-view="chatgpt" type="button" role="tab" aria-selected="false" aria-controls="chatgptPreview" id="tab-chatgpt">ChatGPT</button>
          </div>

          <!-- Google Desktop -->
          <div id="desktopPreview" class="preview-pane active" role="tabpanel" aria-labelledby="tab-desktop">
            <div class="serp-snippet serp-desktop">
              <div class="serp-site">
                <div class="serp-favicon" id="dFavicon">H</div>
                <div class="serp-site-info">
                  <div class="serp-sitename" id="dSiteName">hristijannajcheski.com</div>
                  <div class="serp-url" id="dUrl">https://hristijannajcheski.com › tools › serp-snippet-previewer</div>
                </div>
              </div>
              <div class="serp-flex">
                <div class="serp-main">
                  <h3 class="serp-title" id="dTitle">Your page title will appear here</h3>
                  <div class="serp-rating" id="dRating" style="display:none;"></div>
                  <p class="serp-desc"><span class="serp-date" id="dDate"></span><span id="dDesc">Your meta description will appear here. Start typing in the form to see the preview update in real time.</span></p>
                </div>
                <div class="serp-image" id="dImage" style="display:none;"></div>
              </div>
              <div class="serp-sitelinks" id="dSitelinks" style="display:none;"></div>
              <div class="serp-faq" id="dFaq" style="display:none;"></div>
            </div>
          </div>

          <!-- Google Mobile -->
          <div id="mobilePreview" class="preview-pane" role="tabpanel" aria-labelledby="tab-mobile">
            <div class="serp-snippet serp-mobile">
              <div class="serp-site">
                <div class="serp-favicon" id="mFavicon">H</div>
                <div class="serp-site-info">
                  <div class="serp-sitename" id="mSiteName">hristijannajcheski.com</div>
                  <div class="serp-url" id="mUrl">https://hristijannajcheski.com › tools</div>
                </div>
              </div>
              <div class="serp-flex">
                <div class="serp-main">
                  <h3 class="serp-title" id="mTitle">Your page title will appear here</h3>
                  <div class="serp-rating" id="mRating" style="display:none;"></div>
                  <p class="serp-desc"><span class="serp-date" id="mDate"></span><span id="mDesc">Your meta description will appear here. Start typing in the form to see the preview update in real time.</span></p>
                </div>
                <div class="serp-image" id="mImage" style="display:none;"></div>
              </div>
              <div class="serp-sitelinks serp-sitelinks-mobile" id="mSitelinks" style="display:none;"></div>
              <div class="serp-faq" id="mFaq" style="display:none;"></div>
            </div>
          </div>

          <!-- AI Overview -->
          <div id="aiOverviewPreview" class="preview-pane" role="tabpanel" aria-labelledby="tab-aiOverview">
            <div class="ai-card ai-overview">
              <div class="ai-overview-head">
                <div class="ai-overview-pill">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                  AI Overview
                </div>
                <div class="ai-overview-meta">Generated · From <strong id="aoBrand">your site</strong> + 4 other sources</div>
              </div>
              <p class="ai-overview-body" id="aoBody">Your meta description text will appear here, rephrased and grounded in citations. Train your snippet to be the source — the cleaner your title and description, the higher the citation eligibility.<sup class="ai-cite">[1]</sup></p>
              <div class="ai-overview-srclist">
                <div class="ai-src-head">Sources</div>
                <div class="ai-src">
                  <div class="ai-src-num">1</div>
                  <div class="ai-src-favicon" id="aoFavicon">H</div>
                  <div class="ai-src-body">
                    <div class="ai-src-title" id="aoTitle">Your page title</div>
                    <div class="ai-src-host" id="aoHost">hristijannajcheski.com</div>
                  </div>
                </div>
                <div class="ai-src ai-src-dim">
                  <div class="ai-src-num">2</div>
                  <div class="ai-src-favicon" style="background:#888;">W</div>
                  <div class="ai-src-body">
                    <div class="ai-src-title">Competing source (your competitor's snippet)</div>
                    <div class="ai-src-host">othersite.com</div>
                  </div>
                </div>
              </div>
              <div class="ai-cite-note">Tip: AI Overview prefers concise titles and Q-shaped headings. Title + first 160 chars of description are the strongest signals.</div>
            </div>
          </div>

          <!-- Perplexity -->
          <div id="perplexityPreview" class="preview-pane" role="tabpanel" aria-labelledby="tab-perplexity">
            <div class="ai-card ai-perplexity">
              <div class="px-question">
                <span class="px-icon">?</span>
                <span id="pxQuery">What does the page describe?</span>
              </div>
              <div class="px-sources">
                <div class="px-source px-source-1">
                  <div class="px-src-host"><span class="px-favicon" id="pxFavicon">H</span><span id="pxHost">hristijannajcheski.com</span></div>
                  <div class="px-src-title" id="pxTitle">Your page title</div>
                  <div class="px-src-num">1</div>
                </div>
                <div class="px-source">
                  <div class="px-src-host"><span class="px-favicon" style="background:#0ea5e9;">R</span>reddit.com</div>
                  <div class="px-src-title">Related discussion</div>
                  <div class="px-src-num">2</div>
                </div>
                <div class="px-source">
                  <div class="px-src-host"><span class="px-favicon" style="background:#16a34a;">G</span>github.com</div>
                  <div class="px-src-title">Related repo</div>
                  <div class="px-src-num">3</div>
                </div>
              </div>
              <div class="px-answer">
                <p id="pxBody">Your meta description, rewritten as a direct answer to the user's question. <sup class="px-cite">1</sup> Pages with clear, scannable structure are cited more often. <sup class="px-cite">1</sup></p>
              </div>
              <div class="ai-cite-note">Tip: Perplexity ranks sources by clarity, freshness, and outbound citation count. Your snippet drives the citation — but the page content drives the rank.</div>
            </div>
          </div>

          <!-- ChatGPT -->
          <div id="chatgptPreview" class="preview-pane" role="tabpanel" aria-labelledby="tab-chatgpt">
            <div class="ai-card ai-chatgpt">
              <div class="gpt-row gpt-user">
                <div class="gpt-avatar gpt-avatar-user">U</div>
                <div class="gpt-body"><div id="gptQuery">What does this page describe?</div></div>
              </div>
              <div class="gpt-row gpt-assistant">
                <div class="gpt-avatar gpt-avatar-bot">★</div>
                <div class="gpt-body">
                  <div class="gpt-tool">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
                    Searched the web · 3 sources
                  </div>
                  <p id="gptBody">Based on the page, your meta description is what the model summarizes. Pages whose snippet directly answers the user prompt get the highest citation odds.</p>
                  <div class="gpt-cite-card">
                    <div class="gpt-cite-favicon" id="gptFavicon">H</div>
                    <div class="gpt-cite-body">
                      <div class="gpt-cite-title" id="gptTitle">Your page title</div>
                      <div class="gpt-cite-host" id="gptHost">hristijannajcheski.com</div>
                      <div class="gpt-cite-snippet" id="gptSnippet">Your meta description excerpt…</div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="ai-cite-note">Tip: ChatGPT browse mode pulls the page title verbatim, then a 1-2 sentence excerpt from your description or first paragraph. Front-load the answer.</div>
            </div>
          </div>

          <!-- Analysis -->
          <div class="analysis">
            <div class="analysis-metrics">
              <div class="metric">
                <div class="metric-head">
                  <div class="metric-label">CTR signals</div>
                  <div class="metric-value" id="ctrScoreText">— / 100</div>
                </div>
                <div class="metric-bar"><div id="ctrFill" class="metric-fill metric-fill-ctr"></div></div>
              </div>
              <div class="metric">
                <div class="metric-head">
                  <div class="metric-label">Rewrite risk</div>
                  <div class="metric-value" id="rwLevelText">—</div>
                </div>
                <div class="metric-bar"><div id="rwFill" class="metric-fill metric-fill-rw"></div></div>
              </div>
            </div>

            <div class="analysis-section">
              <div class="analysis-section-label">Power-word + structure checks</div>
              <div class="chips" id="ctrChips"></div>
            </div>

            <div class="analysis-section" id="ctrTipsSection" style="display:none;">
              <div class="analysis-section-label">How to lift this score</div>
              <ul class="tips" id="ctrTips"></ul>
            </div>

            <div class="analysis-section" id="rwReasonsSection" style="display:none;">
              <div class="analysis-section-label">Why Google may rewrite this</div>
              <ul class="tips" id="rwReasons"></ul>
            </div>
          </div>

          <div class="action-bar">
            <button type="button" id="copyShareBtn" class="btn btn-secondary">Copy share link</button>
            <button type="button" id="resetBtn" class="btn btn-secondary">Reset</button>
            <span id="copyShareStatus" class="action-status"></span>
          </div>

          <div class="preview-notes">
            <h4>How the limits work</h4>
            <ul>
              <li><strong>Title:</strong> Google truncates at ~600px (desktop), roughly 50–60 characters. This tool measures pixel width directly — more accurate than character count alone.</li>
              <li><strong>Meta description:</strong> ~920px desktop (~155–160 chars), ~680px mobile (~120 chars). Google rewrites ~70% of meta descriptions anyway, so focus on titles first.</li>
              <li><strong>Bolding:</strong> Google bolds query matches in the snippet. Enter your target keyword above to see how it looks rendered.</li>
              <li><strong>AI engines:</strong> AI Overview, Perplexity, and ChatGPT pull the title verbatim but rephrase the description. Title is the cite-eligibility signal; description is the rephrase source.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <div style="max-width: 760px; margin: 0 auto;">
        <span class="section-label">Related resources</span>
        <h2 class="section-title" style="margin-bottom: var(--space-6);">Beyond <span class="text-gradient">the snippet</span></h2>
        <p style="color: var(--color-text-secondary); line-height: 1.8;">A clean snippet helps CTR, but the page underneath is what wins citations. Run a <a href="/tools/aeo-readiness-audit/" style="color: var(--color-accent-blue);">free AEO readiness audit</a> on the same URL, or generate the <a href="/tools/schema-generator/" style="color: var(--color-accent-blue);">JSON-LD schema</a> AI engines actually consume. For ongoing help, see <a href="/blog/what-is-fractional-seo/" style="color: var(--color-accent-blue);">what a fractional SEO consultant does</a>.</p>
        <div style="display:flex;flex-wrap:wrap;gap:var(--space-3);margin-top:var(--space-6);">
          <a href="/contact/" class="btn btn-orange btn-lg">Free 60-Min Consultation →</a>
          <a href="/tools/" class="btn btn-secondary btn-lg">More AEO & SEO tools →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Snippet looks great. <span class="text-gradient-orange">What about the page?</span></h2>
        <p>The snippet is the headline. The page underneath is what gets cited. If you want a senior SEO read on the full picture, let's talk.</p>
        <a href="/contact/" class="btn btn-orange btn-lg">Book a Free Strategy Call →</a>
      </div>
    </div>
  </section>

  <style>
    .tool-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.25fr);
      gap: var(--space-8);
      align-items: start;
    }
    @media (max-width: 1024px) {
      .tool-layout { grid-template-columns: 1fr; }
    }

    .tool-form {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-7);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      position: sticky;
      top: var(--space-6);
    }
    @media (max-width: 1024px) {
      .tool-form { position: static; }
    }

    .form-field label {
      display: block;
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: var(--text-sm);
      color: var(--color-text-primary);
      margin-bottom: var(--space-3);
    }
    .label-muted {
      color: var(--color-text-muted);
      font-weight: 400;
      font-size: 0.85em;
    }
    .form-field input[type="text"],
    .form-field input[type="email"],
    .form-field input[type="number"],
    .form-field textarea,
    .form-field select {
      width: 100%;
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-3) var(--space-4);
      color: var(--color-text-primary);
      font-family: inherit;
      font-size: var(--text-base);
    }
    .form-field input:focus,
    .form-field textarea:focus,
    .form-field select:focus {
      outline: none;
      border-color: var(--color-accent-blue);
    }
    .form-field .hint {
      margin-top: var(--space-2);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }

    .form-sep {
      border: none;
      border-top: 1px solid var(--color-border);
      margin: 0;
    }

    /* URL fetch row */
    .fetch-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: var(--space-3);
    }
    .fetch-row .btn { padding-left: var(--space-5); padding-right: var(--space-5); }
    .fetch-status {
      margin-top: var(--space-2);
      font-size: var(--text-xs);
      min-height: 16px;
      color: var(--color-text-muted);
    }
    .fetch-status.fetch-ok { color: #10b981; }
    .fetch-status.fetch-err { color: #ef4444; }
    .fetch-status.fetch-loading { color: var(--color-accent-blue); }

    .field-meter {
      margin-top: var(--space-2);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
      font-family: var(--font-mono, ui-monospace, monospace);
    }
    .status { margin-left: var(--space-2); font-weight: 600; }
    .status.ok { color: #10b981; }
    .status.warn { color: #f59e0b; }
    .status.bad { color: #ef4444; }

    /* SERP feature toggles */
    .form-section {
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: 0;
    }
    .form-section > summary {
      cursor: pointer;
      padding: var(--space-3) var(--space-4);
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: var(--text-sm);
      color: var(--color-text-primary);
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .form-section > summary::-webkit-details-marker { display: none; }
    .form-section > summary::after {
      content: '▾';
      color: var(--color-text-muted);
      font-size: 0.7em;
      transition: transform 0.15s ease;
    }
    .form-section[open] > summary::after { transform: rotate(180deg); }
    .form-section-body {
      padding: 0 var(--space-4) var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .toggles {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2) var(--space-3);
    }
    .toggle {
      display: flex !important;
      align-items: center;
      gap: var(--space-2);
      margin-bottom: 0 !important;
      font-size: var(--text-sm) !important;
      font-weight: 500 !important;
      cursor: pointer;
      color: var(--color-text-secondary) !important;
    }
    .toggle input[type="checkbox"] {
      width: 16px;
      height: 16px;
      accent-color: #f97316;
      cursor: pointer;
    }
    .feature-detail {
      display: none;
      padding: var(--space-3);
      background: var(--color-bg-secondary);
      border-radius: var(--radius-sm);
      flex-direction: column;
      gap: var(--space-2);
    }
    .feature-detail.show { display: flex; }
    .feature-detail .sub-label {
      font-size: var(--text-xs) !important;
      color: var(--color-text-muted) !important;
