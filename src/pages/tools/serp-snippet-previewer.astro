      return out;
    }

    function keywordIndexWordSafe(tLower: string, kw: string): number {
      if (!kw) return -1;
      const re = new RegExp(`\\b${escapeRegex(kw)}\\b`, 'i');
      const m = tLower.match(re);
      return m && m.index !== undefined ? m.index : tLower.indexOf(kw);
    }

    function analyzeCtr(title: string, desc: string): CtrSignals {
      const tLower = title.toLowerCase();
      const dLower = desc.toLowerCase();
      const tokens = getKeywordTokens();
      const primaryKw = (tokens[0] || '').toLowerCase();
      const currentYear = new Date().getFullYear();

      const hasNumber = /\d/.test(title);
      const hasYear = /\b20\d{2}\b/.test(title);
      // Require properly matched bracket pairs — '[Free)' should not pass.
      const hasBracket = /\[[^\]]+\]|\([^)]+\)|\{[^}]+\}/.test(title);
      const hasQuestion = /\?/.test(title) || /^(how|what|why|when|where|which)\b/i.test(title.trim());
      const matchedPowerWords = matchPowerWords(tLower);
      const hasPowerWord = matchedPowerWords.length > 0;
      const titleHasKeyword = !!primaryKw && keywordIndexWordSafe(tLower, primaryKw) >= 0;
      const descHasKeyword = !!primaryKw && keywordIndexWordSafe(dLower, primaryKw) >= 0;
      const KEYWORD_EARLY_THRESHOLD = 30;
      const keywordEarlyInTitle = titleHasKeyword && keywordIndexWordSafe(tLower, primaryKw) <= KEYWORD_EARLY_THRESHOLD;

      let score = 0;
      if (hasNumber) score += 12;
      if (hasYear) score += 10;
      if (hasBracket) score += 10;
      if (hasPowerWord) score += Math.min(matchedPowerWords.length * 7, 20);
      if (hasQuestion) score += 10;
      if (titleHasKeyword) score += 20;
      if (keywordEarlyInTitle) score += 8;
      if (descHasKeyword) score += 10;
      if (title.trim().length >= 30) score += 5;
      score = Math.min(100, score);

      const tips: string[] = [];

      // If there's no title at all, that's the only thing worth telling them.
      // Adding 'use a number' / 'add a year' to an empty title is noise.
      if (title.trim().length === 0) {
        tips.push('Add a page title — this is the single biggest CTR signal. Without it Google substitutes whatever it finds.');
        if (desc.trim().length === 0) {
          tips.push('Add a meta description — otherwise Google pulls a snippet from page body, often awkwardly.');
        }
        return {
          hasNumber, hasYear, hasBracket, hasPowerWord, matchedPowerWords,
          hasQuestion, titleHasKeyword, descHasKeyword, keywordEarlyInTitle,
          score, tips,
        };
      }

      if (primaryKw && !titleHasKeyword) {
        tips.push(`Add "${tokens[0]}" to the title — exact-match keyword is the strongest CTR signal.`);
      } else if (primaryKw && titleHasKeyword && !keywordEarlyInTitle) {
        tips.push(`Move "${tokens[0]}" closer to the start of the title — first ${KEYWORD_EARLY_THRESHOLD} characters get scanned first.`);
      }
      if (primaryKw && !descHasKeyword && desc.trim().length > 0) {
        tips.push(`Mention "${tokens[0]}" once in the meta description so Google bolds the match.`);
      }
      if (!hasNumber) tips.push('Add a number ("12 tips", "5 reasons", "3 ways"). Numerals beat words for CTR.');
      if (!hasYear) tips.push(`Add the current year ("${currentYear}") if the page is fresh — signals recency.`);
      if (!hasBracket) tips.push(`Try a bracket modifier — "[Free]", "(Updated)", "[${currentYear}]". Brackets pull the eye.`);
      if (!hasPowerWord) tips.push('Use a power word — "free", "ultimate", "essential", "proven".');
      if (measure(title, TITLE_FONT) > TITLE_MAX_PX) {
        tips.push('Title overflows the SERP — trim until the meter shows under the limit.');
      }
      if (title.length < 30) tips.push('Title is short. Aim for ~40–55 characters for a stronger snippet.');
      if (desc.trim().length === 0) {
        tips.push('Add a meta description — Google will pull from page body otherwise.');
      } else {
        if (desc.length < 80) tips.push('Description is short. Google may rewrite using page body content.');
        if (desc.length > 160) tips.push('Description may be truncated. Trim to ~155 chars to keep the full message visible.');
      }

      return {
        hasNumber, hasYear, hasBracket, hasPowerWord, matchedPowerWords,
        hasQuestion, titleHasKeyword, descHasKeyword, keywordEarlyInTitle,
        score, tips,
      };
    }

    type RewriteRisk = { level: 'low' | 'medium' | 'high'; score: number; reasons: string[] };
    function rewriteRisk(title: string, desc: string): RewriteRisk {
      let risk = 25; // baseline — Google rewrites titles ~60% of the time
      const reasons: string[] = [];
      const tokens = getKeywordTokens();
      const primaryKw = (tokens[0] || '').toLowerCase();

      if (title.length === 0) {
        risk += 40;
        reasons.push('No title provided — Google will substitute one from the page H1 or body.');
      } else {
        if (title.length < 20) { risk += 18; reasons.push('Title is too short — Google often pads short titles with brand or related text.'); }
        if (title.length > 60) { risk += 12; reasons.push('Title may be truncated — Google often substitutes a shorter alternative from the H1.'); }
        if (primaryKw && keywordIndexWordSafe(title.toLowerCase(), primaryKw) < 0) {
          risk += 15;
          reasons.push('Title does not contain the target keyword — Google will likely substitute one that does.');
        }
        // Brand delimiter check: require a space-flanked separator near the end
        // (last 25 chars) so 'step-by-step' or '12-month' don't false-positive.
        const tail = title.slice(Math.max(0, title.length - 25));
        const hasBrandDelimiter = /\s[\|—·]\s|\s-\s/.test(tail);
        if (!hasBrandDelimiter) {
          risk += 5;
          reasons.push('No brand delimiter near the end — Google often appends "| Brand" itself.');
        }
        // ALL-CAPS: require at least one letter AND no lowercase letters.
        if (/[A-Za-z]/.test(title) && !/[a-z]/.test(title) && title.length > 10) {
          risk += 10;
          reasons.push('Title is in ALL CAPS — Google typically rewrites these to title case.');
        }
      }
      if (desc.length === 0) {
        risk += 20;
        reasons.push('No meta description — Google will pull a snippet from page body.');
      } else {
        if (desc.length < 80) { risk += 12; reasons.push('Description is short — Google may rewrite using page body content.'); }
        if (desc.length > 160) { risk += 8; reasons.push('Description may be truncated — Google may rewrite to fit the snippet box.'); }
      }

      risk = Math.min(100, risk);
      const level: RewriteRisk['level'] = risk < 35 ? 'low' : risk < 65 ? 'medium' : 'high';
      return { level, score: risk, reasons };
    }

    // ============ URL formatting ============
    function formatUrlForSerp(raw: string): { sitename: string; breadcrumb: string } {
      try {
        const u = new URL(raw);
        const host = u.hostname.replace(/^www\./, '');
        const parts = u.pathname.split('/').filter(Boolean);
        const breadcrumb = `${u.protocol}//${host}${parts.length ? ' › ' + parts.join(' › ') : ''}`;
        return { sitename: host, breadcrumb };
      } catch {
        return { sitename: 'hristijannajcheski.com', breadcrumb: raw || 'https://hristijannajcheski.com' };
      }
    }

    // ============ Update everything ============
    function setStatus(el: HTMLElement, px: number, max: number) {
      el.classList.remove('ok', 'warn', 'bad');
      if (px === 0) { el.textContent = ''; return; }
      if (px <= max * 0.85) { el.textContent = '· Good length'; el.classList.add('ok'); }
      else if (px <= max) { el.textContent = '· Close to limit'; el.classList.add('warn'); }
      else { el.textContent = '· Too long (will be truncated)'; el.classList.add('bad'); }
    }

    function renderRatingHtml(value: number, count: number): string {
      const v = Math.max(0, Math.min(5, value));
      const filled = Math.round(v);
      const stars = '★★★★★'.slice(0, filled) + '☆☆☆☆☆'.slice(0, 5 - filled);
      return `<span class="serp-stars">${stars}</span> Rating: ${v.toFixed(1)} · <strong>${count.toLocaleString()}</strong> review${count === 1 ? '' : 's'}`;
    }

    function renderSitelinksHtml(items: string[]): string {
      return items.filter(Boolean).slice(0, 4).map(item => {
        const parts = item.split('—');
        const name = (parts[0] || item).trim();
        const desc = parts.slice(1).join('—').trim();
        return `<div><a class="serp-sitelink" href="#">${escapeHtml(name)}</a>${desc ? `<div class="serp-sitelink-desc">${escapeHtml(desc)}</div>` : ''}</div>`;
      }).join('');
    }

    function renderFaqHtml(items: string[]): string {
      return items.filter(Boolean).slice(0, 3).map(q =>
        `<div class="serp-faq-item"><span>${boldKeyword(q)}</span><span class="serp-faq-chev">⌄</span></div>`
      ).join('');
    }

    let faviconUrl: string | null = null;
    function setFavicon(el: HTMLElement, fallback: string) {
      const safe = faviconUrl ? safeUrl(faviconUrl) : '';
      if (!safe) {
        el.textContent = fallback;
        return;
      }
      el.textContent = '';
      const img = document.createElement('img');
      img.alt = '';
      img.src = safe;
      img.addEventListener('error', () => { el.textContent = fallback; });
      el.appendChild(img);
    }

    function update() {
      const titleRaw = $i(FIELDS.title).value;
      const descRaw = $t(FIELDS.description).value;
      const title = titleRaw || PLACEHOLDER_TITLE;
      const desc = descRaw || PLACEHOLDER_DESC;
      const { sitename, breadcrumb } = formatUrlForSerp($i(FIELDS.url).value);
      const sitenameInitial = sitename[0]?.toUpperCase() || 'H';

      // Mobile breadcrumb is shorter
      const breadcrumbMobile = (() => {
        try {
          const u = new URL($i(FIELDS.url).value);
          const host = u.hostname.replace(/^www\./, '');
          const parts = u.pathname.split('/').filter(Boolean).slice(0, 2);
          return host + (parts.length ? ' › ' + parts.join(' › ') : '');
        } catch { return sitename; }
      })();

      // Title truncation for each surface
      const truncatedTitleDesktop = truncateAtPixel(title, TITLE_FONT, TITLE_MAX_PX);
      const truncatedTitleMobile = truncateAtPixel(title, '400 18px arial, sans-serif', TITLE_MAX_PX - 80);
      const truncatedDescDesktop = truncateAtPixel(desc, DESC_FONT, DESC_DESKTOP_MAX_PX);
      const truncatedDescMobile = truncateAtPixel(desc, DESC_FONT, 680);

      // === Google Desktop ===
      $('dTitle').innerHTML = boldKeyword(truncatedTitleDesktop);
      $('dDesc').innerHTML = boldKeyword(truncatedDescDesktop);
      $('dUrl').textContent = breadcrumb;
      $('dSiteName').textContent = sitename;
      setFavicon($('dFavicon'), sitenameInitial);

      // === Google Mobile ===
      $('mTitle').innerHTML = boldKeyword(truncatedTitleMobile);
      $('mDesc').innerHTML = boldKeyword(truncatedDescMobile);
      $('mUrl').textContent = breadcrumbMobile;
      $('mSiteName').textContent = sitename;
      setFavicon($('mFavicon'), sitenameInitial);

      // === Date prefix ===
      const datePrefix = $i(FIELDS.ftDate).checked
        ? ($s(FIELDS.dateChoice).value === 'today' ? 'Today — ' : `${$s(FIELDS.dateChoice).value} — `)
        : '';
      $('dDate').textContent = datePrefix;
      $('mDate').textContent = datePrefix;

      // === Rating ===
      const ratingOn = $i(FIELDS.ftRating).checked;
      if (ratingOn) {
        const v = parseFloat($i(FIELDS.ratingValue).value || '0') || 0;
        const c = parseInt($i(FIELDS.reviewCount).value || '0', 10) || 0;
        const html = renderRatingHtml(v, c);
        $('dRating').innerHTML = html;
        $('dRating').style.display = '';
        $('mRating').innerHTML = html;
        $('mRating').style.display = '';
      } else {
        $('dRating').style.display = 'none';
        $('mRating').style.display = 'none';
      }

      // === Sitelinks ===
      const slOn = $i(FIELDS.ftSitelinks).checked;
      if (slOn) {
        const items = [$i('sl1').value, $i('sl2').value, $i('sl3').value, $i('sl4').value];
        const html = renderSitelinksHtml(items);
        if (html) {
          $('dSitelinks').innerHTML = html;
          $('dSitelinks').style.display = '';
          $('mSitelinks').innerHTML = html;
          $('mSitelinks').style.display = '';
        } else {
          $('dSitelinks').style.display = 'none';
          $('mSitelinks').style.display = 'none';
        }
      } else {
        $('dSitelinks').style.display = 'none';
        $('mSitelinks').style.display = 'none';
      }

      // === FAQ ===
      const faqOn = $i(FIELDS.ftFaq).checked;
      if (faqOn) {
        const items = [$i('faq1').value, $i('faq2').value, $i('faq3').value].filter(Boolean);
        if (items.length) {
          const html = renderFaqHtml(items);
          $('dFaq').innerHTML = html;
          $('dFaq').style.display = '';
          $('mFaq').innerHTML = html;
          $('mFaq').style.display = '';
        } else {
          $('dFaq').style.display = 'none';
          $('mFaq').style.display = 'none';
        }
      } else {
        $('dFaq').style.display = 'none';
        $('mFaq').style.display = 'none';
      }

      // === Image thumbnail ===
      const imgOn = $i(FIELDS.ftImage).checked;
      if (imgOn) {
        const safe = safeUrl($i(FIELDS.imageUrl).value);
        if (safe) {
          $('dImage').innerHTML = `<img src="${escapeHtml(safe)}" alt="" />`;
          $('mImage').innerHTML = `<img src="${escapeHtml(safe)}" alt="" />`;
        } else {
          $('dImage').innerHTML = '';
          $('mImage').innerHTML = '';
        }
        $('dImage').style.display = '';
        $('mImage').style.display = '';
      } else {
        $('dImage').style.display = 'none';
        $('mImage').style.display = 'none';
      }

      // === AI Overview ===
      $('aoTitle').innerHTML = boldKeyword(truncatedTitleDesktop);
      $('aoHost').textContent = sitename;
      $('aoBrand').textContent = sitename;
      const aoBody = descRaw ? `${descRaw.replace(/\s+/g, ' ').slice(0, 280)}` : PLACEHOLDER_DESC;
      $('aoBody').innerHTML = boldKeyword(aoBody) + '<sup class="ai-cite">[1]</sup>';
      setFavicon($('aoFavicon'), sitenameInitial);

      // === Perplexity ===
      const primaryKw = getKeywordTokens()[0];
      $('pxQuery').textContent = primaryKw ? `What is ${primaryKw}?` : 'What does the page describe?';
      $('pxTitle').innerHTML = boldKeyword(truncatedTitleMobile);
      $('pxHost').textContent = sitename;
      const pxAnswer = descRaw
        ? `${descRaw.replace(/\s+/g, ' ').slice(0, 220)}`
        : 'Your meta description, rewritten as a direct answer to the user\'s question.';
      $('pxBody').innerHTML = boldKeyword(pxAnswer) + ' <sup class="px-cite">1</sup>';
      setFavicon($('pxFavicon'), sitenameInitial);

      // === ChatGPT ===
      $('gptQuery').textContent = primaryKw ? `Tell me about ${primaryKw}` : 'What does this page describe?';
      $('gptTitle').innerHTML = boldKeyword(truncatedTitleDesktop);
      $('gptHost').textContent = sitename;
      $('gptSnippet').innerHTML = boldKeyword(descRaw ? descRaw.slice(0, 160) : PLACEHOLDER_DESC.slice(0, 160)) + '…';
      $('gptBody').innerHTML = `Based on <strong>${escapeHtml(sitename)}</strong>, ${boldKeyword(descRaw ? descRaw.replace(/\s+/g, ' ').slice(0, 220) : 'the page describes ' + (primaryKw || 'the topic') + ' with structured guidance.')}`;
      setFavicon($('gptFavicon'), sitenameInitial);

      // === Meters ===
      const tPx = measure(titleRaw, TITLE_FONT);
      const dPx = measure(descRaw, DESC_FONT);
      $('titleChars').textContent = String(titleRaw.length);
      $('titlePx').textContent = String(tPx);
      setStatus($('titleStatus'), tPx, TITLE_MAX_PX);
      $('descChars').textContent = String(descRaw.length);
      $('descPx').textContent = String(dPx);
      setStatus($('descStatus'), dPx, DESC_DESKTOP_MAX_PX);

      // === Analysis ===
      const ctr = analyzeCtr(titleRaw, descRaw);
      const rw = rewriteRisk(titleRaw, descRaw);

      $('ctrScoreText').textContent = `${ctr.score} / 100`;
      ($('ctrFill') as HTMLElement).style.width = `${ctr.score}%`;
      $('rwLevelText').textContent = `${rw.level.toUpperCase()} · ${rw.score}/100`;
      ($('rwFill') as HTMLElement).style.width = `${rw.score}%`;

      // Chips
      const chipDefs: { ok: boolean; label: string }[] = [
        { ok: ctr.hasNumber, label: 'Number' },
        { ok: ctr.hasYear, label: 'Year (20XX)' },
        { ok: ctr.hasBracket, label: 'Bracket modifier' },
        { ok: ctr.hasPowerWord, label: ctr.matchedPowerWords.length ? `Power word: ${ctr.matchedPowerWords.slice(0, 2).join(', ')}` : 'Power word' },
        { ok: ctr.hasQuestion, label: 'Question hook' },
        { ok: ctr.titleHasKeyword, label: 'Keyword in title' },
        { ok: ctr.descHasKeyword, label: 'Keyword in desc' },
        { ok: ctr.keywordEarlyInTitle, label: 'Keyword early in title' },
      ];
      $('ctrChips').innerHTML = chipDefs.map(c =>
        `<span class="chip ${c.ok ? 'chip-ok' : 'chip-miss'}">${c.ok ? '✓' : '○'} ${escapeHtml(c.label)}</span>`
      ).join('');

      // Tips
      if (ctr.tips.length) {
        $('ctrTips').innerHTML = ctr.tips.map(t => `<li>${escapeHtml(t)}</li>`).join('');
        $('ctrTipsSection').style.display = '';
      } else {
        $('ctrTipsSection').style.display = 'none';
      }

      // Rewrite reasons
      if (rw.reasons.length) {
        $('rwReasons').innerHTML = rw.reasons.map(r => `<li>${escapeHtml(r)}</li>`).join('');
        $('rwReasonsSection').style.display = '';
      } else {
        $('rwReasonsSection').style.display = 'none';
      }

      // Show/hide feature-detail blocks
      ['ftDate','ftRating','ftSitelinks','ftFaq','ftImage'].forEach(id => {
        const on = $i(id).checked;
        const detail = document.querySelector(`.feature-detail[data-for="${id}"]`) as HTMLElement | null;
        if (detail) detail.classList.toggle('show', on);
      });
    }

    // ============ URL Fetch ============
    async function doFetch() {
      const raw = $i(FIELDS.fetchUrl).value.trim();
      const statusEl = $('fetchStatus');
      if (!raw) {
        statusEl.className = 'fetch-status fetch-err';
        statusEl.textContent = 'Paste a URL first.';
        return;
      }
      statusEl.className = 'fetch-status fetch-loading';
      statusEl.textContent = 'Fetching… (up to 10 seconds)';
      ($('fetchBtn') as HTMLButtonElement).disabled = true;
      try {
        const r = await fetch('/api/serp-fetch', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: raw }),
        });
        const j = await r.json();
        if (!r.ok || !j.ok) {
          statusEl.className = 'fetch-status fetch-err';
          statusEl.textContent = j.error || 'Could not fetch that URL.';
          return;
        }
        const d = j.data;
        if (d.title) $i(FIELDS.title).value = d.title;
        if (d.metaDescription) $t(FIELDS.description).value = d.metaDescription;
        if (d.finalUrl) $i(FIELDS.url).value = d.finalUrl;
        if (d.faviconUrl) faviconUrl = d.faviconUrl;

        // Auto-detect rich results and toggle them
        if (d.hasReview && d.ratingValue) {
          $i(FIELDS.ftRating).checked = true;
          if (d.ratingValue) $i(FIELDS.ratingValue).value = String(d.ratingValue);
          if (d.reviewCount) $i(FIELDS.reviewCount).value = String(d.reviewCount);
        }
        if (d.hasFaq && d.faqQuestions && d.faqQuestions.length) {
          $i(FIELDS.ftFaq).checked = true;
          if (d.faqQuestions[0]) $i('faq1').value = d.faqQuestions[0];
          if (d.faqQuestions[1]) $i('faq2').value = d.faqQuestions[1];
          if (d.faqQuestions[2]) $i('faq3').value = d.faqQuestions[2];
        }
        if (d.hasArticle && d.publishDate) {
          $i(FIELDS.ftDate).checked = true;
        }
        if (d.ogImage) {
          $i(FIELDS.ftImage).checked = true;
          $i(FIELDS.imageUrl).value = d.ogImage;
        }

        const detected: string[] = [];
        if (d.hasArticle) detected.push('Article');
        if (d.hasFaq) detected.push('FAQ');
        if (d.hasReview) detected.push('Review/Rating');
        if (d.hasProduct) detected.push('Product');
        if (d.hasBreadcrumb) detected.push('Breadcrumb');
        if (d.hasLocalBusiness) detected.push('Organization');

        statusEl.className = 'fetch-status fetch-ok';
        statusEl.textContent = `Loaded · HTTP ${d.httpStatus} · ${d.durationMs}ms${detected.length ? ' · Schema: ' + detected.join(', ') : ' · No schema detected'}`;

        update();
      } catch (e) {
        statusEl.className = 'fetch-status fetch-err';
        statusEl.textContent = 'Network error. Try again.';
      } finally {
        ($('fetchBtn') as HTMLButtonElement).disabled = false;
      }
    }

    // ============ Lead capture (full report) ============
    async function submitLead() {
      const email = $i('leadEmail').value.trim();
      const hp = $i('hp').value;
      const statusEl = $('leadStatus');
      if (!email) {
        statusEl.className = 'lead-status err';
        statusEl.textContent = 'Email is required.';
        return;
      }
      ($('reportBtn') as HTMLButtonElement).disabled = true;
      statusEl.className = 'lead-status';
      statusEl.textContent = 'Generating report…';

      const titleRaw = $i(FIELDS.title).value;
      const descRaw = $t(FIELDS.description).value;
      const tokens = getKeywordTokens();
      const ctr = analyzeCtr(titleRaw, descRaw);
      const rw = rewriteRisk(titleRaw, descRaw);

      const detected: string[] = [];
      if ($i(FIELDS.ftDate).checked) detected.push('Date');
      if ($i(FIELDS.ftRating).checked) detected.push('Star rating');
      if ($i(FIELDS.ftSitelinks).checked) detected.push('Sitelinks');
      if ($i(FIELDS.ftFaq).checked) detected.push('FAQ');
      if ($i(FIELDS.ftImage).checked) detected.push('Image');

      try {
        const r = await fetch('/api/lead-capture', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tool: 'serp-optimizer',
            email,
            url: $i(FIELDS.url).value || $i(FIELDS.fetchUrl).value,
            honeypot: hp,
            payload: {
              title: titleRaw,
              description: descRaw,
              keyword: tokens.join(', '),
              titleChars: titleRaw.length,
              titlePx: measure(titleRaw, TITLE_FONT),
              descChars: descRaw.length,
              descPx: measure(descRaw, DESC_FONT),
              ctr: { score: ctr.score, tips: ctr.tips, matchedPowerWords: ctr.matchedPowerWords },
              rewriteRisk: { level: rw.level, score: rw.score, reasons: rw.reasons },
              detectedRichResults: detected,
            },
          }),
        });
        const j = await r.json();
        if (!r.ok || j.ok === false) {
          statusEl.className = 'lead-status err';
          statusEl.textContent = j.error || j.message || 'Something went wrong. Try again.';
          return;
        }
        statusEl.className = 'lead-status ok';
        statusEl.textContent = j.message || 'Sent — check your inbox.';
        $i('leadEmail').value = '';
      } catch {
        statusEl.className = 'lead-status err';
        statusEl.textContent = 'Network error. Try again.';
      } finally {
        ($('reportBtn') as HTMLButtonElement).disabled = false;
      }
    }

    // ============ Share link ============
    function buildShareLink(): string {
      const params = new URLSearchParams();
      const setIf = (key: string, val: string) => { if (val) params.set(key, val); };
      setIf('t', $i(FIELDS.title).value);
      setIf('d', $t(FIELDS.description).value);
      setIf('u', $i(FIELDS.url).value);
      setIf('k', $i(FIELDS.keyword).value);
      // Feature toggles + values
      const feats: string[] = [];
      if ($i(FIELDS.ftDate).checked) feats.push('date');
      if ($i(FIELDS.ftRating).checked) feats.push('rating');
      if ($i(FIELDS.ftSitelinks).checked) feats.push('sitelinks');
      if ($i(FIELDS.ftFaq).checked) feats.push('faq');
      if ($i(FIELDS.ftImage).checked) feats.push('image');
      if (feats.length) params.set('f', feats.join(','));
      if ($i(FIELDS.ftRating).checked) {
        params.set('rv', $i(FIELDS.ratingValue).value);
        params.set('rc', $i(FIELDS.reviewCount).value);
      }
      if ($i(FIELDS.ftSitelinks).checked) {
        const sl = [$i('sl1').value, $i('sl2').value, $i('sl3').value, $i('sl4').value].filter(Boolean).join('|');
        if (sl) params.set('sl', sl);
      }
      if ($i(FIELDS.ftFaq).checked) {
        const fq = [$i('faq1').value, $i('faq2').value, $i('faq3').value].filter(Boolean).join('|');
        if (fq) params.set('fq', fq);
      }
      if ($i(FIELDS.ftImage).checked && $i(FIELDS.imageUrl).value) params.set('img', $i(FIELDS.imageUrl).value);
      if ($i(FIELDS.ftDate).checked) params.set('dt', $s(FIELDS.dateChoice).value);
      return `${window.location.origin}${window.location.pathname}?${params.toString()}`;
    }

    async function copyShareLink() {
      const link = buildShareLink();
      const statusEl = $('copyShareStatus');
      try {
        await navigator.clipboard.writeText(link);
        statusEl.textContent = 'Copied!';
        setTimeout(() => { statusEl.textContent = ''; }, 2000);
      } catch {
        // Fallback: open in new tab so user can copy
        window.prompt('Copy this link:', link);
      }
    }

    function loadFromUrl() {
      const params = new URLSearchParams(window.location.search);
      if (params.has('t')) $i(FIELDS.title).value = params.get('t') || '';
      if (params.has('d')) $t(FIELDS.description).value = params.get('d') || '';
      if (params.has('u')) $i(FIELDS.url).value = params.get('u') || '';
      if (params.has('k')) $i(FIELDS.keyword).value = params.get('k') || '';
      const feats = (params.get('f') || '').split(',').filter(Boolean);
      const featMap: Record<string, string> = {
        date: 'ftDate', rating: 'ftRating', sitelinks: 'ftSitelinks',
        faq: 'ftFaq', image: 'ftImage',
      };
      for (const f of feats) {
        const id = featMap[f];
        if (id) $i(id).checked = true;
      }
      if (params.has('rv')) $i(FIELDS.ratingValue).value = params.get('rv') || '';
      if (params.has('rc')) $i(FIELDS.reviewCount).value = params.get('rc') || '';
      if (params.has('sl')) {
        const sls = (params.get('sl') || '').split('|');
        if (sls[0]) $i('sl1').value = sls[0];
        if (sls[1]) $i('sl2').value = sls[1];
        if (sls[2]) $i('sl3').value = sls[2];
        if (sls[3]) $i('sl4').value = sls[3];
      }
      if (params.has('fq')) {
        const fqs = (params.get('fq') || '').split('|');
        if (fqs[0]) $i('faq1').value = fqs[0];
        if (fqs[1]) $i('faq2').value = fqs[1];
        if (fqs[2]) $i('faq3').value = fqs[2];
      }
      if (params.has('img')) $i(FIELDS.imageUrl).value = params.get('img') || '';
      if (params.has('dt')) $s(FIELDS.dateChoice).value = params.get('dt') || 'today';
      // Drop the query string after loading so a refresh shows the user's
      // current edits, not the original snapshot.
      if (params.toString()) {
        window.history.replaceState(null, '', window.location.pathname);
      }
    }

    function resetAll() {
      const ids = Object.values(FIELDS);
      for (const id of ids) {
        const el = document.getElementById(id) as
          | HTMLInputElement
          | HTMLTextAreaElement
          | HTMLSelectElement
          | null;
        if (!el) continue;
        if ('checked' in el && (el as HTMLInputElement).type === 'checkbox') {
          (el as HTMLInputElement).checked = false;
        } else if (el.tagName === 'SELECT') {
          (el as HTMLSelectElement).value = 'today';
        } else {
          (el as HTMLInputElement | HTMLTextAreaElement).value = '';
        }
      }
      faviconUrl = null;
      $('fetchStatus').textContent = '';
      $('fetchStatus').className = 'fetch-status';
      window.history.replaceState(null, '', window.location.pathname);
      update();
    }

    // ============ Wire up ============
    function wire() {
      // Watch all inputs for live updates
      Object.values(FIELDS).forEach(id => {
        const el = $(id);
        if (el) {
          el.addEventListener('input', update);
          el.addEventListener('change', update);
        }
      });

      $('fetchBtn').addEventListener('click', doFetch);
      $i(FIELDS.fetchUrl).addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          doFetch();
        }
      });

      $('reportBtn').addEventListener('click', submitLead);
      $i('leadEmail').addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          e.preventDefault();
          submitLead();
        }
      });

      $('copyShareBtn').addEventListener('click', copyShareLink);
      $('resetBtn').addEventListener('click', resetAll);

      // Tab switching
      document.querySelectorAll('.preview-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          const view = (btn as HTMLElement).dataset.view;
          document.querySelectorAll('.preview-tab').forEach(b => {
            b.classList.remove('active');
            b.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');
          document.querySelectorAll('.preview-pane').forEach(p => p.classList.remove('active'));
          $(view + 'Preview')?.classList.add('active');
        });
      });
    }

    loadFromUrl();
    wire();
    update();
  </script>
</BaseLayout>
