---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout
  title="Fractional SEO ROI Calculator | Free 12-Month Projection | Hristijan Najcheski"
  description="Model the revenue impact of fractional SEO with real numbers. Three scenarios, payback period, year-1 ROI multiple, cost vs full-time hire vs agency. Free, instant."
>
  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <span class="section-label">SEO Tool · Highest intent</span>
        <h1>Fractional SEO <span class="text-gradient">ROI Calculator</span></h1>
        <p>Plug in your current traffic and conversion numbers — get a realistic 12-month revenue projection across three scenarios, your payback month, your ROI multiple, and how it compares to a full-time hire or an agency. Free and instant.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="roi-layout">
        <form class="roi-form" id="roiForm">
          <h3 class="roi-form-heading">Your numbers</h3>

          <div class="form-field">
            <label for="traffic">Current monthly organic traffic</label>
            <input type="number" id="traffic" min="0" step="100" value="15000" />
            <p class="field-helper">Sessions/month from organic search. Check Google Analytics or Search Console.</p>
          </div>

          <div class="form-field">
            <label for="cvr">Conversion rate (%)</label>
            <input type="number" id="cvr" min="0" max="100" step="0.1" value="2.5" />
            <p class="field-helper">% of organic visitors who complete the goal (purchase, signup, lead).</p>
          </div>

          <div class="form-field">
            <label for="aov">Average order value / customer LTV ($)</label>
            <input type="number" id="aov" min="0" step="10" value="250" />
            <p class="field-helper">Use LTV if SaaS or subscription. AOV if e-commerce. First-order value if B2B.</p>
          </div>

          <div class="form-field">
            <label for="industry">Industry</label>
            <select id="industry">
              <option value="saas">SaaS / Subscription</option>
              <option value="ecommerce" selected>E-Commerce</option>
              <option value="publishing">Publishing / Media</option>
              <option value="local">Local Services</option>
              <option value="b2b">B2B Services</option>
              <option value="other">Other</option>
            </select>
            <p class="field-helper">Adjusts projections — SaaS and B2B compound more; publishing converts thinner.</p>
          </div>

          <div class="form-field">
            <label for="investment">Fractional investment ($/month)</label>
            <input type="number" id="investment" min="0" step="500" value="6000" />
            <p class="field-helper">Typical fractional engagement range: $3K–$10K/mo. <a href="/pricing/" style="color:var(--color-accent-blue);">See pricing →</a></p>
          </div>
        </form>

        <div class="roi-results">
          <div class="result-card result-card-hero">
            <div class="result-tag">Expected case · Year 1</div>
            <div class="result-headline" id="netGain">$0</div>
            <div class="result-sub" id="resultSub">net gain · — × ROI · payback —</div>
          </div>

          <div class="scenario-grid">
            <div class="scenario-card" data-color="conservative">
              <h4>Conservative <span id="liftConservative" class="lift">+0%</span></h4>
              <dl>
                <dt>Y1 revenue lift</dt><dd id="revConservative">$0</dd>
                <dt>Net gain</dt><dd id="netConservative">$0</dd>
                <dt>ROI</dt><dd id="roiConservative">—×</dd>
                <dt>Payback</dt><dd id="paybackConservative">—</dd>
              </dl>
            </div>
            <div class="scenario-card scenario-card-featured" data-color="expected">
              <h4>Expected <span id="liftExpected" class="lift">+0%</span></h4>
              <dl>
                <dt>Y1 revenue lift</dt><dd id="revExpected">$0</dd>
                <dt>Net gain</dt><dd id="netExpected">$0</dd>
                <dt>ROI</dt><dd id="roiExpected">—×</dd>
                <dt>Payback</dt><dd id="paybackExpected">—</dd>
              </dl>
            </div>
            <div class="scenario-card" data-color="ambitious">
              <h4>Ambitious <span id="liftAmbitious" class="lift">+0%</span></h4>
              <dl>
                <dt>Y1 revenue lift</dt><dd id="revAmbitious">$0</dd>
                <dt>Net gain</dt><dd id="netAmbitious">$0</dd>
                <dt>ROI</dt><dd id="roiAmbitious">—×</dd>
                <dt>Payback</dt><dd id="paybackAmbitious">—</dd>
              </dl>
            </div>
          </div>

          <div class="chart-card">
            <h4>12-month revenue ramp (expected case)</h4>
            <div class="chart" id="chart"></div>
          </div>

          <div class="compare-card">
            <h4>Cost vs the alternatives</h4>
            <table class="compare-table">
              <tr><td>Full-time senior SEO hire</td><td>$165k/yr</td><td class="muted">+ benefits, ramp, 1 person</td></tr>
              <tr><td>Mid-tier agency retainer</td><td>$144k/yr</td><td class="muted">Junior team, slow turnaround</td></tr>
              <tr class="compare-row-active"><td>Fractional (your scenario)</td><td id="fracAnnual">$0/yr</td><td class="muted">Senior, dedicated, flexible</td></tr>
            </table>
          </div>

          <div class="email-gate">
            <h3>Want this projection emailed as a full report?</h3>
            <p>Includes the 12-month month-by-month breakdown, all three scenarios, and a written walkthrough of the assumptions.</p>
            <form id="gateForm" class="gate-form">
              <input type="email" id="gateEmail" placeholder="you@yourcompany.com" required />
              <input type="text" name="company" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
              <button type="submit" class="btn btn-orange btn-lg" id="gateSubmit">Email me the full report →</button>
            </form>
            <p class="gate-fineprint">Free. No spam. I will personally follow up if I see a strong fit.</p>
          </div>

          <div class="gate-success" id="gateSuccess" hidden>
            <div class="success-tick">✓</div>
            <h3 id="successHeading">Sent!</h3>
            <p id="successMsg">The full report is on its way.</p>
            <a href="/contact/" class="btn btn-orange btn-lg" style="margin-top:var(--space-4);">Skip the email — book a call now →</a>
          </div>
        </div>
      </div>

      <div class="roi-notes">
        <h3>How the projection is built</h3>
        <p>The model is intentionally conservative. It uses an S-curve ramp — small gains months 1-3, acceleration through months 4-9, plateau by month 12. Industry multiplier adjusts the baseline lift (SaaS/B2B compound harder, publishing thinner). Three scenarios bracket the realistic range. Numbers are projections, not promises — every market is different, and execution quality dominates everything.</p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>The number is interesting. <span class="text-gradient-orange">Let's see if it's real for you.</span></h2>
        <p>The calculator gives you a range. A 60-minute call gives you a specific plan. Free, no obligation, no slides.</p>
        <a href="/contact/" class="btn btn-orange btn-lg">Book Free 60-Min Consultation →</a>
      </div>
    </div>
  </section>

  <style>
    .roi-layout {
      display: grid;
      grid-template-columns: minmax(0, 380px) minmax(0, 1fr);
      gap: var(--space-8);
      align-items: start;
    }
    @media (max-width: 980px) {
      .roi-layout { grid-template-columns: 1fr; }
    }

    .roi-form {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-7);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      position: sticky;
      top: 100px;
    }
    @media (max-width: 980px) {
      .roi-form { position: static; }
    }
    .roi-form-heading {
      font-family: var(--font-heading);
      font-size: 1rem;
      color: var(--color-text-muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: var(--space-4);
    }
    .form-field label {
      display: block;
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: var(--text-sm);
      color: var(--color-text-primary);
      margin-bottom: var(--space-3);
    }
    .form-field input,
    .form-field select {
      width: 100%;
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-3) var(--space-4);
      color: var(--color-text-primary);
      font-family: inherit;
      font-size: var(--text-base);
    }
    .form-field input:focus, .form-field select:focus {
      outline: none;
      border-color: var(--color-accent-blue);
    }
    .field-helper {
      margin-top: var(--space-2);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
      line-height: 1.5;
    }

    .roi-results { display: flex; flex-direction: column; gap: var(--space-5); }
    .result-card {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-7);
    }
    .result-card-hero {
      background: linear-gradient(135deg, #0b1220 0%, #1f2937 100%);
      border: 1px solid #1f2937;
      color: #fff;
    }
    .result-tag {
      font-size: var(--text-xs);
      color: #9ca3af;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 700;
    }
    .result-headline {
      font-family: var(--font-heading);
      font-size: 3rem;
      font-weight: 900;
      line-height: 1.05;
      margin-top: var(--space-3);
      color: #fff;
    }
    .result-sub {
      color: #cbd5e1;
      font-size: var(--text-sm);
      margin-top: var(--space-3);
    }

    .scenario-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }
    @media (max-width: 760px) {
      .scenario-grid { grid-template-columns: 1fr; }
    }
    .scenario-card {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
    }
    .scenario-card[data-color="conservative"] { border-top: 3px solid #f59e0b; }
    .scenario-card[data-color="expected"] { border-top: 3px solid #3b82f6; }
    .scenario-card[data-color="ambitious"] { border-top: 3px solid #10b981; }
    .scenario-card-featured {
      box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.4);
    }
    .scenario-card h4 {
      font-family: var(--font-heading);
      font-size: 1rem;
      margin-bottom: var(--space-4);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .scenario-card .lift {
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--color-text-muted);
    }
    .scenario-card dl { margin: 0; display: grid; grid-template-columns: auto 1fr; gap: var(--space-2) var(--space-3); font-size: var(--text-sm); }
    .scenario-card dt { color: var(--color-text-muted); }
    .scenario-card dd { margin: 0; text-align: right; font-weight: 600; color: var(--color-text-primary); }

    .chart-card, .compare-card {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
    }
    .chart-card h4, .compare-card h4 {
      font-family: var(--font-heading);
      font-size: 1rem;
      margin-bottom: var(--space-5);
    }
    .chart {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 4px;
      align-items: end;
      height: 160px;
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--color-border);
    }
    .chart-bar {
      background: linear-gradient(to top, #3b82f6, #60a5fa);
      border-radius: 4px 4px 0 0;
      min-height: 4px;
      transition: height 0.4s ease;
      position: relative;
    }
    .chart-bar:hover::after {
      content: attr(data-tip);
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translateX(-50%);
      background: #0b1220;
      color: #fff;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 11px;
      white-space: nowrap;
    }
    .chart-labels {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 4px;
      margin-top: 6px;
      font-size: 10px;
      color: var(--color-text-muted);
      text-align: center;
    }

    .compare-table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--text-sm);
    }
    .compare-table td {
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--color-border);
    }
    .compare-table td:nth-child(2) { text-align: right; font-weight: 700; }
    .compare-table td.muted { color: var(--color-text-muted); padding-left: var(--space-4); font-weight: 400; }
    .compare-row-active td { color: var(--color-text-primary); font-weight: 700; }
    .compare-row-active td.muted { color: var(--color-text-muted); font-weight: 400; }

    .email-gate {
      background: linear-gradient(135deg, rgba(249, 115, 22, 0.08), rgba(37, 99, 235, 0.05));
      border: 1px solid rgba(249, 115, 22, 0.25);
      border-radius: var(--radius-xl);
      padding: var(--space-7);
    }
    .email-gate h3 {
      font-family: var(--font-heading);
      font-size: 1.25rem;
      margin-bottom: var(--space-3);
    }
    .email-gate p {
      color: var(--color-text-secondary);
      line-height: 1.7;
      margin-bottom: var(--space-5);
    }
    .gate-form { display: flex; gap: var(--space-3); }
    @media (max-width: 700px) { .gate-form { flex-direction: column; } }
    .gate-form input[type="email"] {
      flex: 1;
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-4) var(--space-5);
      color: var(--color-text-primary);
      font-size: var(--text-base);
      font-family: inherit;
    }
    .hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
    .gate-fineprint { font-size: var(--text-xs); color: var(--color-text-muted); margin-top: var(--space-3); }

    .gate-success {
      text-align: center;
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-8);
    }
    .success-tick {
      width: 64px; height: 64px;
      border-radius: 50%;
      background: #10b981;
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 32px; font-weight: 800;
      margin: 0 auto var(--space-4);
    }
    .gate-success h3 { font-family: var(--font-heading); font-size: 1.4rem; }
    .gate-success p { color: var(--color-text-secondary); margin-top: var(--space-2); }

    .roi-notes {
      margin-top: var(--space-10);
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-7);
      max-width: 820px;
      margin-left: auto;
      margin-right: auto;
    }
    .roi-notes h3 {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      margin-bottom: var(--space-3);
    }
    .roi-notes p { color: var(--color-text-secondary); line-height: 1.8; }
  </style>

  <script>
    type Industry = 'saas' | 'ecommerce' | 'publishing' | 'local' | 'b2b' | 'other';
    type Scenario = 'conservative' | 'expected' | 'ambitious';

    const INDUSTRY_MULT: Record<Industry, number> = {
      saas: 1.3, ecommerce: 1.0, publishing: 0.9, local: 1.1, b2b: 1.4, other: 1.0,
    };
    const SCENARIO_LIFT: Record<Scenario, number> = {
      conservative: 0.30, expected: 0.75, ambitious: 1.50,
    };
    const RAMP = [0.03, 0.08, 0.16, 0.28, 0.42, 0.57, 0.70, 0.80, 0.87, 0.92, 0.96, 1.0];

    function fmtUsd(n: number): string {
      const abs = Math.abs(n);
      if (abs >= 1_000_000) return `${n < 0 ? '-' : ''}$${(abs / 1_000_000).toFixed(2)}M`;
      if (abs >= 1_000) return `${n < 0 ? '-' : ''}$${(abs / 1000).toFixed(1)}k`;
      return `${n < 0 ? '-' : ''}$${abs.toLocaleString('en-US')}`;
    }

    interface Inputs {
      traffic: number; cvr: number; aov: number; investment: number; industry: Industry;
    }

    function compute(inputs: Inputs, scenario: Scenario) {
      const lift = SCENARIO_LIFT[scenario] * INDUSTRY_MULT[inputs.industry];
      const baselineRevenue = inputs.traffic * (inputs.cvr / 100) * inputs.aov;
      let cumRev = 0, cumInv = 0, payback: number | null = null;
      const months = RAMP.map((r, i) => {
        const month = i + 1;
        const traffic = inputs.traffic * (1 + r * lift);
        const conv = traffic * (inputs.cvr / 100);
        const rev = conv * inputs.aov;
        const incremental = Math.max(0, rev - baselineRevenue);
        cumRev += incremental;
        cumInv += inputs.investment;
        if (payback === null && cumRev - cumInv >= 0 && cumInv > 0) payback = month;
        return { month, traffic, revenue: rev, incremental, cumNet: cumRev - cumInv };
      });
      return {
        lift,
        totalRevenue: cumRev,
        totalInvestment: cumInv,
        netGain: cumRev - cumInv,
        roi: cumInv > 0 ? cumRev / cumInv : 0,
        payback,
        months,
      };
    }

    const trafficEl = document.getElementById('traffic') as HTMLInputElement;
    const cvrEl = document.getElementById('cvr') as HTMLInputElement;
    const aovEl = document.getElementById('aov') as HTMLInputElement;
    const investmentEl = document.getElementById('investment') as HTMLInputElement;
    const industryEl = document.getElementById('industry') as HTMLSelectElement;
    const chartEl = document.getElementById('chart')!;

    function gather(): Inputs {
      return {
        traffic: Number(trafficEl.value) || 0,
        cvr: Number(cvrEl.value) || 0,
        aov: Number(aovEl.value) || 0,
        investment: Number(investmentEl.value) || 0,
        industry: industryEl.value as Industry,
      };
    }

    function renderChart(months: { revenue: number; month: number }[]) {
      const max = Math.max(...months.map((m) => m.revenue), 1);
      chartEl.innerHTML = months.map((m) => {
        const h = Math.max(4, Math.round((m.revenue / max) * 150));
        return `<div class="chart-bar" style="height:${h}px;" data-tip="M${m.month}: ${fmtUsd(Math.round(m.revenue))}"></div>`;
      }).join('');
    }

    function render() {
      const inputs = gather();
      const c = compute(inputs, 'conservative');
      const e = compute(inputs, 'expected');
      const a = compute(inputs, 'ambitious');

      (document.getElementById('netGain') as HTMLElement).textContent = fmtUsd(Math.round(e.netGain));
      (document.getElementById('resultSub') as HTMLElement).textContent =
        `${e.roi.toFixed(1)}× ROI · payback ${e.payback ? 'month ' + e.payback : 'not in 12 mo'} · ${Math.round(e.months[11].traffic).toLocaleString()} mo visits at end of year`;

      const cards: [string, typeof e][] = [
        ['Conservative', c],
        ['Expected', e],
        ['Ambitious', a],
      ];
      for (const [name, s] of cards) {
        const k = name.toLowerCase();
        document.getElementById('lift' + name)!.textContent = `+${Math.round(s.lift * 100)}%`;
        document.getElementById('rev' + name)!.textContent = fmtUsd(Math.round(s.totalRevenue));
        document.getElementById('net' + name)!.textContent = fmtUsd(Math.round(s.netGain));
        document.getElementById('roi' + name)!.textContent = s.roi.toFixed(1) + '×';
        document.getElementById('payback' + name)!.textContent = s.payback ? 'Month ' + s.payback : '>12 mo';
      }

      document.getElementById('fracAnnual')!.textContent = fmtUsd(inputs.investment * 12) + '/yr';
      renderChart(e.months);
    }

    [trafficEl, cvrEl, aovEl, investmentEl, industryEl].forEach((el) => {
      el.addEventListener('input', render);
      el.addEventListener('change', render);
    });
    render();

    // Email gate
    const gateForm = document.getElementById('gateForm') as HTMLFormElement;
    const gateEmail = document.getElementById('gateEmail') as HTMLInputElement;
    const gateSubmit = document.getElementById('gateSubmit') as HTMLButtonElement;
    const gateBox = document.querySelector('.email-gate') as HTMLElement;
    const gateSuccess = document.getElementById('gateSuccess')!;
    const successMsg = document.getElementById('successMsg')!;

    gateForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = gateEmail.value.trim();
      const hp = (gateForm.querySelector('.hp') as HTMLInputElement).value;
      const inputs = gather();
      gateSubmit.disabled = true; gateSubmit.textContent = 'Sending…';
      try {
        const res = await fetch('/api/lead-capture', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tool: 'roi-calculator',
            email,
            honeypot: hp,
            payload: {
              monthlyOrganicTraffic: inputs.traffic,
              conversionRatePct: inputs.cvr,
              avgOrderValue: inputs.aov,
              monthlyInvestment: inputs.investment,
              industry: inputs.industry,
            },
          }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        successMsg.textContent = data.message || 'The full report is on its way.';
        gateBox.hidden = true;
        gateSuccess.removeAttribute('hidden');
      } catch (err: any) {
        alert(err.message || 'Something went wrong. Try again.');
      } finally {
        gateSubmit.disabled = false; gateSubmit.textContent = 'Email me the full report →';
      }
    });
  </script>
</BaseLayout>
