---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  {
    slug: 'aeo-readiness-audit',
    title: 'AEO Readiness Audit',
    description: 'Paste any URL and grade how AI-ready it is. Scores 20 signals ChatGPT, Perplexity, and Google AI Overview use to decide which pages to cite.',
    icon: '🎯',
    status: 'live',
    featured: true,
    tag: 'AEO',
  },
  {
    slug: 'llms-txt-generator',
    title: 'llms.txt Generator',
    description: 'Build the new robots.txt-for-AI standard. Tell ChatGPT, Claude, Perplexity, and Gemini which content on your site to read first.',
    icon: '🤖',
    status: 'live',
    tag: 'AEO',
  },
  {
    slug: 'serp-snippet-previewer',
    title: 'SERP Snippet Previewer',
    description: 'See how your title and meta description will appear in Google — desktop and mobile — with pixel-width and character-count warnings.',
    icon: '🔍',
    status: 'live',
    tag: 'SEO',
  },
  {
    slug: 'robots-txt-tester',
    title: 'Robots.txt Tester',
    description: 'Paste your robots.txt and a URL to check which rules apply for Googlebot, Bingbot, GPTBot, ClaudeBot, and other crawlers.',
    icon: '🛡️',
    status: 'live',
    tag: 'SEO',
  },
  {
    slug: 'roi-calculator',
    title: 'Fractional SEO ROI Calculator',
    description: 'Plug in your current traffic and conversion data to model 12-month revenue lift, payback period, and ROI multiple. Three scenarios.',
    icon: '📈',
    status: 'live',
    tag: 'SEO',
  },
  {
    slug: 'schema-generator',
    title: 'Schema Markup Generator',
    description: 'Generate copy-ready JSON-LD for Organization, LocalBusiness, FAQ, Article, Product, and Breadcrumb — the schema AI engines actually consume.',
    icon: '🧩',
    status: 'live',
    tag: 'AEO',
  },
  {
    slug: 'hreflang-generator',
    title: 'Hreflang Tag Generator',
    description: 'Input your languages and regions, get valid hreflang link tags with reciprocal x-default — ready to drop into your <head>.',
    icon: '🌍',
    status: 'live',
    tag: 'SEO',
  },
  {
    slug: 'ai-brand-visibility',
    title: 'AI Brand Visibility Checker',
    description: 'Find out what AI engines actually say about your brand. Side-by-side answers from Claude, GPT, and Perplexity for any domain.',
    icon: '👁️',
    status: 'soon',
    tag: 'AEO',
  },
];
---

<BaseLayout
  title="Free AEO & SEO Tools | For the AI-Era of Search | Hristijan Najcheski"
  description="Free, no-signup tools for AEO (Answer Engine Optimization) and traditional SEO. AEO readiness audit, llms.txt generator, schema, robots.txt tester, and more. Built by a fractional SEO consultant."
>
  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <span class="section-label">Free AEO & SEO Tools</span>
        <h1>Tools built<br /><span class="text-gradient">for the AI era of search</span></h1>
        <p>AEO (Answer Engine Optimization) is the new fight — ranking inside ChatGPT, Perplexity, Claude, and Google AI Overview. These tools help you get there, plus the SEO fundamentals underneath. Free, no signup to use.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="tools-grid">
        {tools.map((tool) => (
          tool.status === 'live' ? (
            <a href={`/tools/${tool.slug}/`} class:list={["tool-card", { 'tool-card-featured': tool.featured }]}>
              {tool.tag && <span class={`tool-tag tool-tag-${(tool.tag || '').toLowerCase()}`}>{tool.tag}</span>}
              <div class="tool-icon">{tool.icon}</div>
              <h3 class="tool-title">{tool.title}</h3>
              <p class="tool-desc">{tool.description}</p>
              <span class="tool-cta">Open tool →</span>
            </a>
          ) : (
            <div class="tool-card tool-card-soon">
              {tool.tag && <span class={`tool-tag tool-tag-${(tool.tag || '').toLowerCase()}`}>{tool.tag}</span>}
              <div class="tool-icon">{tool.icon}</div>
              <h3 class="tool-title">{tool.title}</h3>
              <p class="tool-desc">{tool.description}</p>
              <span class="tool-cta tool-cta-soon">Coming soon</span>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Need more than a tool? <span class="text-gradient-orange">Let's talk strategy.</span></h2>
        <p>These tools help with the tactical work. If you need senior SEO leadership embedded in your team, that's what fractional SEO is for.</p>
        <a href="/contact/" class="btn btn-orange btn-lg">Book a Free Strategy Call →</a>
      </div>
    </div>
  </section>

  <style>
    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: var(--space-6);
      margin-top: var(--space-8);
    }
    .tool-card {
      display: flex;
      flex-direction: column;
      position: relative;
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-8) var(--space-8) var(--space-7);
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s ease, transform 0.2s ease;
    }
    .tool-card-featured {
      border-color: rgba(249, 115, 22, 0.5);
      background: linear-gradient(135deg, var(--color-bg-elevated), rgba(249, 115, 22, 0.04));
    }
    .tool-tag {
      position: absolute;
      top: var(--space-4);
      right: var(--space-5);
      font-size: 0.62rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 4px;
    }
    .tool-tag-aeo {
      background: rgba(249, 115, 22, 0.12);
      color: #f97316;
      border: 1px solid rgba(249, 115, 22, 0.3);
    }
    .tool-tag-seo {
      background: rgba(37, 99, 235, 0.1);
      color: var(--color-accent-blue);
      border: 1px solid rgba(37, 99, 235, 0.25);
    }
    a.tool-card:hover {
      border-color: var(--color-accent-blue);
      transform: translateY(-2px);
    }
    .tool-card-soon {
      opacity: 0.65;
    }
    .tool-icon {
      font-size: 2rem;
      margin-bottom: var(--space-3);
    }
    .tool-title {
      font-family: var(--font-heading);
      font-size: var(--text-lg);
      font-weight: 700;
      color: var(--color-text-primary);
      margin-bottom: var(--space-2);
    }
    .tool-desc {
      color: var(--color-text-secondary);
      font-size: var(--text-sm);
      line-height: 1.6;
      flex-grow: 1;
      margin-bottom: var(--space-4);
    }
    .tool-cta {
      color: var(--color-accent-blue);
      font-size: var(--text-sm);
      font-weight: 600;
    }
    .tool-cta-soon {
      color: var(--color-text-muted);
    }
  </style>
</BaseLayout>
