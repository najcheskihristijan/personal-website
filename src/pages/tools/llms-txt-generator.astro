---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;
---

<BaseLayout
  title="Free llms.txt Generator | The Robots.txt for AI Engines | Hristijan Najcheski"
  description="Generate a copy-paste ready llms.txt file for your site — the emerging standard that tells ChatGPT, Perplexity, Claude, and Gemini which content to read first. Free, no signup."
>
  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <span class="section-label">AEO Tool · New standard</span>
        <h1>llms.txt <span class="text-gradient">Generator</span></h1>
        <p>llms.txt is the emerging standard that tells AI engines — ChatGPT, Perplexity, Claude, Gemini — which content on your site to read first. Fill in the form, copy the file, drop it at <code>/llms.txt</code>.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="llms-layout">
        <div class="llms-form">
          <div class="form-field">
            <label for="siteName">Site / brand name</label>
            <input type="text" id="siteName" placeholder="Acme Inc." />
          </div>
          <div class="form-field">
            <label for="siteDomain">Domain (without protocol)</label>
            <input type="text" id="siteDomain" placeholder="acme.com" />
          </div>
          <div class="form-field">
            <label for="siteTagline">One-line description</label>
            <input type="text" id="siteTagline" placeholder="B2B SaaS for inventory automation, built for mid-market retail." />
          </div>
          <div class="form-field">
            <label for="siteAbout">Longer description (what should AI know about you?)</label>
            <textarea id="siteAbout" rows="4" placeholder="Acme helps retailers automate stock-level forecasting using machine-learning models trained on point-of-sale data. Founded 2021, HQ in Berlin, serves customers in 12 countries."></textarea>
          </div>

          <div class="form-field">
            <label>Key pages AI should prioritize</label>
            <div id="pagesList" class="pages-list"></div>
            <button type="button" class="btn btn-secondary" id="addPageBtn" style="margin-top:var(--space-3);">+ Add page</button>
          </div>

          <div class="form-field">
            <label>Optional sections</label>
            <div class="opt-row">
              <label class="opt"><input type="checkbox" id="optDocs" checked /> Documentation</label>
              <label class="opt"><input type="checkbox" id="optBlog" checked /> Blog</label>
              <label class="opt"><input type="checkbox" id="optPolicies" /> Policies (privacy, terms)</label>
              <label class="opt"><input type="checkbox" id="optProducts" /> Products / pricing</label>
            </div>
          </div>
        </div>

        <div class="llms-output">
          <div class="output-head">
            <h3>Your llms.txt</h3>
            <div class="output-actions">
              <button class="btn btn-secondary" id="copyBtn">Copy</button>
              <button class="btn btn-secondary" id="downloadBtn">Download</button>
            </div>
          </div>
          <pre id="llmsOutput" class="llms-output-pre"># Fill in the form to generate</pre>

          <div class="email-gate-inline">
            <h4>Want me to email this to you + audit your AI visibility?</h4>
            <form id="gateForm" class="gate-form">
              <input type="email" id="gateEmail" placeholder="you@yourcompany.com" required />
              <input type="text" name="company" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
              <button type="submit" class="btn btn-orange" id="gateSubmit">Email me the file →</button>
            </form>
            <p class="gate-fineprint">Free. No spam. I will follow up personally if I spot quick wins.</p>
          </div>
          <div class="gate-success" id="gateSuccess" hidden>
            <div class="success-tick">✓</div>
            <p id="successMsg">Sent! Check your inbox.</p>
          </div>
        </div>
      </div>

      <div class="llms-notes">
        <h3>How to use your llms.txt</h3>
        <ol>
          <li>Save the file as <code>llms.txt</code> (plain text).</li>
          <li>Upload it to your domain root so it is reachable at <code>https://yourdomain.com/llms.txt</code>.</li>
          <li>That's it — AI engines that respect the standard will pick it up on their next crawl.</li>
        </ol>
        <p><strong>Why this matters:</strong> AI engines have token budgets per page. <code>llms.txt</code> is your chance to tell them exactly which URLs to prioritize, in what order, and how to summarize you — instead of letting them guess from your menu or footer.</p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>llms.txt is the start. <span class="text-gradient-orange">AEO is the strategy.</span></h2>
        <p>Generating the file takes a minute. Making AI engines actually cite you takes a real plan — schema, content shape, freshness, citations, authority. That's what fractional SEO solves.</p>
        <a href="/contact/" class="btn btn-orange btn-lg">Book a Free Strategy Call →</a>
      </div>
    </div>
  </section>

  <style>
    .llms-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: var(--space-8);
      align-items: start;
    }
    @media (max-width: 980px) {
      .llms-layout { grid-template-columns: 1fr; }
    }

    .llms-form {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-8);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }
    .form-field label {
      display: block;
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: var(--text-sm);
      color: var(--color-text-primary);
      margin-bottom: var(--space-3);
    }
    .form-field input[type="text"],
    .form-field input[type="url"],
    .form-field input[type="email"],
    .form-field textarea {
      width: 100%;
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-3) var(--space-4);
      color: var(--color-text-primary);
      font-family: inherit;
      font-size: var(--text-base);
    }
    .form-field input:focus, .form-field textarea:focus {
      outline: none;
      border-color: var(--color-accent-blue);
    }

    .pages-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .page-row {
      display: grid;
      grid-template-columns: 1fr 1.4fr auto;
      gap: var(--space-2);
    }
    .page-row input {
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-3);
      color: var(--color-text-primary);
      font-size: var(--text-sm);
      font-family: inherit;
    }
    .page-row button {
      background: transparent;
      border: 1px solid var(--color-border);
      color: var(--color-text-muted);
      border-radius: var(--radius-md);
      cursor: pointer;
      padding: 0 var(--space-3);
    }
    .opt-row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-3);
    }
    .opt {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: var(--text-sm);
      color: var(--color-text-secondary);
    }

    .llms-output {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-7);
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      position: sticky;
      top: 100px;
    }
    @media (max-width: 980px) {
      .llms-output { position: static; }
    }
    .output-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .output-head h3 {
      font-family: var(--font-heading);
      font-size: 1.05rem;
    }
    .output-actions {
      display: flex;
      gap: var(--space-2);
    }
    .output-actions .btn {
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-sm);
    }
    .llms-output-pre {
      background: #0b1220;
      color: #e5e7eb;
      padding: var(--space-5);
      border-radius: var(--radius-md);
      font-family: ui-monospace, Menlo, Consolas, monospace;
      font-size: 13px;
      line-height: 1.6;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-word;
      max-height: 460px;
    }

    .email-gate-inline {
      background: linear-gradient(135deg, rgba(249, 115, 22, 0.08), rgba(37, 99, 235, 0.05));
      border: 1px solid rgba(249, 115, 22, 0.2);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
    }
    .email-gate-inline h4 {
      font-family: var(--font-heading);
      font-size: 1rem;
      margin-bottom: var(--space-3);
    }
    .gate-form {
      display: flex;
      gap: var(--space-2);
    }
    .gate-form input[type="email"] {
      flex: 1;
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-3) var(--space-4);
      color: var(--color-text-primary);
      font-size: var(--text-sm);
    }
    @media (max-width: 500px) {
      .gate-form { flex-direction: column; }
    }
    .hp { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
    .gate-fineprint {
      font-size: var(--text-xs);
      color: var(--color-text-muted);
      margin-top: var(--space-3);
    }
    .gate-success {
      text-align: center;
      padding: var(--space-5);
      background: var(--color-bg-secondary);
      border-radius: var(--radius-md);
    }
    .success-tick {
      width: 40px; height: 40px;
      background: #10b981;
      color: #fff;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto var(--space-2);
      font-size: 20px; font-weight: 800;
    }

    .llms-notes {
      margin-top: var(--space-10);
      background: var(--color-bg-secondary);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-7);
      max-width: 820px;
      margin-left: auto;
      margin-right: auto;
    }
    .llms-notes h3 {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      margin-bottom: var(--space-3);
    }
    .llms-notes ol {
      color: var(--color-text-secondary);
      line-height: 1.8;
      padding-left: 1.5rem;
      margin-bottom: var(--space-4);
    }
    .llms-notes p { color: var(--color-text-secondary); line-height: 1.7; }
    code {
      background: var(--color-bg-primary);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      padding: 2px 6px;
      font-size: 0.9em;
    }
  </style>

  <script>
    const siteName = document.getElementById('siteName') as HTMLInputElement;
    const siteDomain = document.getElementById('siteDomain') as HTMLInputElement;
    const siteTagline = document.getElementById('siteTagline') as HTMLInputElement;
    const siteAbout = document.getElementById('siteAbout') as HTMLTextAreaElement;
    const pagesList = document.getElementById('pagesList')!;
    const addPageBtn = document.getElementById('addPageBtn')!;
    const optDocs = document.getElementById('optDocs') as HTMLInputElement;
    const optBlog = document.getElementById('optBlog') as HTMLInputElement;
    const optPolicies = document.getElementById('optPolicies') as HTMLInputElement;
    const optProducts = document.getElementById('optProducts') as HTMLInputElement;
    const output = document.getElementById('llmsOutput')!;
    const copyBtn = document.getElementById('copyBtn')!;
    const downloadBtn = document.getElementById('downloadBtn')!;
    const gateForm = document.getElementById('gateForm') as HTMLFormElement;
    const gateEmail = document.getElementById('gateEmail') as HTMLInputElement;
    const gateSubmit = document.getElementById('gateSubmit') as HTMLButtonElement;
    const gateSuccess = document.getElementById('gateSuccess')!;
    const successMsg = document.getElementById('successMsg')!;

    function makePageRow(title = '', url = '') {
      const row = document.createElement('div');
      row.className = 'page-row';
      row.innerHTML = `
        <input type="text" placeholder="Title" value="${title.replace(/"/g, '&quot;')}" />
        <input type="text" placeholder="https://yourdomain.com/page/" value="${url.replace(/"/g, '&quot;')}" />
        <button type="button" aria-label="Remove">×</button>
      `;
      const inputs = row.querySelectorAll('input');
      inputs.forEach((i) => i.addEventListener('input', regenerate));
      row.querySelector('button')!.addEventListener('click', () => { row.remove(); regenerate(); });
      pagesList.appendChild(row);
    }

    makePageRow('About', '');
    makePageRow('Pricing', '');
    makePageRow('Contact', '');

    addPageBtn.addEventListener('click', () => { makePageRow(); regenerate(); });
    [siteName, siteDomain, siteTagline, siteAbout, optDocs, optBlog, optPolicies, optProducts].forEach((el) => {
      el.addEventListener('input', regenerate);
      el.addEventListener('change', regenerate);
    });

    function gather() {
      const name = siteName.value.trim() || 'Your Brand';
      const domain = siteDomain.value.trim().replace(/^https?:\/\//, '').replace(/\/$/, '') || 'yourdomain.com';
      const tagline = siteTagline.value.trim();
      const about = siteAbout.value.trim();
      const pages: { title: string; url: string }[] = [];
      pagesList.querySelectorAll('.page-row').forEach((r) => {
        const inputs = r.querySelectorAll('input') as NodeListOf<HTMLInputElement>;
        const t = inputs[0]?.value.trim();
        let u = inputs[1]?.value.trim();
        if (!u) return;
        if (!/^https?:\/\//.test(u)) u = `https://${domain}${u.startsWith('/') ? u : '/' + u}`;
        if (t || u) pages.push({ title: t || u, url: u });
      });
      return {
        name,
        domain,
        tagline,
        about,
        pages,
        opts: {
          docs: optDocs.checked,
          blog: optBlog.checked,
          policies: optPolicies.checked,
          products: optProducts.checked,
        },
      };
    }

    function regenerate() {
      const d = gather();
      let txt = `# ${d.name}\n\n`;
      if (d.tagline) txt += `> ${d.tagline}\n\n`;
      if (d.about) txt += `${d.about}\n\n`;
      if (d.pages.length) {
        txt += `## Key pages\n\n`;
        for (const p of d.pages) txt += `- [${p.title}](${p.url})\n`;
        txt += `\n`;
      }
      const optional: string[] = [];
      if (d.opts.docs) optional.push(`- [Documentation](https://${d.domain}/docs/)`);
      if (d.opts.blog) optional.push(`- [Blog](https://${d.domain}/blog/)`);
      if (d.opts.products) optional.push(`- [Products](https://${d.domain}/products/)`);
      if (d.opts.policies) {
        optional.push(`- [Privacy policy](https://${d.domain}/privacy/)`);
        optional.push(`- [Terms of service](https://${d.domain}/terms/)`);
      }
      if (optional.length) {
        txt += `## Additional resources\n\n${optional.join('\n')}\n\n`;
      }
      txt += `## Contact\n\n- Website: https://${d.domain}\n`;
      output.textContent = txt;
    }

    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(output.textContent || '');
        const orig = copyBtn.textContent;
        copyBtn.textContent = 'Copied ✓';
        setTimeout(() => (copyBtn.textContent = orig), 1500);
      } catch { /* noop */ }
    });

    downloadBtn.addEventListener('click', () => {
      const blob = new Blob([output.textContent || ''], { type: 'text/plain' });
      const u = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = u; a.download = 'llms.txt';
      document.body.appendChild(a); a.click(); a.remove();
      URL.revokeObjectURL(u);
    });

    gateForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = gateEmail.value.trim();
      const hp = (gateForm.querySelector('.hp') as HTMLInputElement).value;
      const d = gather();
      gateSubmit.disabled = true; gateSubmit.textContent = 'Sending…';
      try {
        const res = await fetch('/api/lead-capture', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tool: 'llms-txt',
            email,
            url: `https://${d.domain}`,
            honeypot: hp,
            payload: { domain: d.domain, llmsTxt: output.textContent },
          }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed');
        successMsg.textContent = data.message || 'Sent! Check your inbox.';
        gateForm.style.display = 'none';
        gateSuccess.removeAttribute('hidden');
      } catch (err: any) {
        alert(err.message || 'Something went wrong. Try again.');
      } finally {
        gateSubmit.disabled = false; gateSubmit.textContent = 'Email me the file →';
      }
    });

    regenerate();
  </script>
</BaseLayout>
