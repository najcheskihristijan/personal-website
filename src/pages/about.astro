---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Hristijan Najcheski | Fractional SEO Consultant"
  description="Learn about Hristijan Najcheski, a fractional SEO consultant with 8+ years of experience helping businesses grow through strategic, data-driven search engine optimization."
  schemaType="person"
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <span class="section-label">About Me</span>
        <h1>The SEO consultant<br />your business <span class="text-gradient">deserves</span></h1>
        <p>
          Senior-level SEO expertise, embedded directly in your team — without the agency overhead.
        </p>
      </div>
    </div>
  </section>

  <!-- About Content -->
  <section class="section">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <h2>Hi, I'm <span class="text-gradient">Hristijan</span></h2>
          <p>
            I'm a Fractional SEO Consultant who works as an extension of your
            marketing team. With over 8 years of hands-on experience in search
            engine optimization, I've helped businesses across SaaS, e-commerce,
            publishing, and enterprise sectors unlock sustainable organic growth.
          </p>
          <p>
            Unlike traditional agencies that juggle dozens of clients, I take on
            a limited number of engagements to ensure every business I work with
            gets the strategic depth and personal attention they deserve. I don't
            just execute tactics — I develop comprehensive SEO strategies aligned
            with your business goals.
          </p>
          <p>
            My approach combines deep technical expertise with content strategy
            and data analytics. I believe in transparency, measurable results,
            and building SEO foundations that deliver long-term, compounding returns.
          </p>
        </div>
        <div class="about-highlights">
          <div class="highlight-card">
            <div class="highlight-value">50+</div>
            <div class="highlight-label">Projects Completed</div>
          </div>
          <div class="highlight-card">
            <div class="highlight-value">8+</div>
            <div class="highlight-label">Years in SEO</div>
          </div>
          <div class="highlight-card">
            <div class="highlight-value">3x</div>
            <div class="highlight-label">Avg. Traffic Increase</div>
          </div>
          <div class="highlight-card">
            <div class="highlight-value">15+</div>
            <div class="highlight-label">Industries Served</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- My Approach -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <span class="section-label">My Approach</span>
      <h2 class="section-title">How I <span class="text-gradient">work</span></h2>
      <p class="section-subtitle">
        A strategic, methodical approach to SEO that delivers sustainable results.
      </p>

      <div class="approach-grid">
        <div class="approach-card">
          <div class="approach-number">01</div>
          <h3>Discovery & Audit</h3>
          <p class="card-text">
            I start every engagement with a deep dive into your business,
            competitors, and current SEO landscape. A comprehensive audit
            reveals opportunities and sets the strategic direction.
          </p>
        </div>

        <div class="approach-card">
          <div class="approach-number">02</div>
          <h3>Strategy & Roadmap</h3>
          <p class="card-text">
            Based on the audit findings, I develop a prioritized SEO roadmap
            aligned with your business goals. Every recommendation is tied
            to expected impact and effort.
          </p>
        </div>

        <div class="approach-card">
          <div class="approach-number">03</div>
          <h3>Execution & Optimization</h3>
          <p class="card-text">
            I work alongside your team to implement changes, create content
            strategies, build links, and continuously optimize based on
            performance data and algorithm updates.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise -->
  <section class="section">
    <div class="container">
      <span class="section-label">Expertise</span>
      <h2 class="section-title">What I <span class="text-gradient-orange">bring to the table</span></h2>
      <div class="services-grid" style="margin-top: var(--space-10);">
        <div class="card">
          <h3 class="card-title">Technical Mastery</h3>
          <p class="card-text">
            Deep understanding of site architecture, rendering, crawl optimization,
            Core Web Vitals, structured data, and JavaScript SEO.
          </p>
        </div>
        <div class="card">
          <h3 class="card-title">Content Strategy</h3>
          <p class="card-text">
            Keyword research, topic clustering, content gap analysis, and
            editorial strategy that drives organic traffic and conversions.
          </p>
        </div>
        <div class="card">
          <h3 class="card-title">Data & Analytics</h3>
          <p class="card-text">
            Advanced analytics setup, custom reporting, A/B testing, and
            data-driven decision-making using GA4, GSC, and enterprise tools.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Let's build your <span class="text-gradient">SEO strategy</span></h2>
        <p>
          Ready to work with a consultant who genuinely cares about your results?
        </p>
        <a href="/contact/" class="btn btn-primary btn-lg">Get in Touch →</a>
      </div>
    </div>
  </section>
</BaseLayout>
