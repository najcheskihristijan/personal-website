---
export const prerender = false;

import { readFileSync } from 'fs';
import { join } from 'path';

const raw = readFileSync(join(process.cwd(), 'src/private/coworking-plan.html'), 'utf-8');
const bodyMatch = raw.match(/<body[^>]*>([\s\S]*)<\/body>/i);
const styleMatch = raw.match(/<style[^>]*>([\s\S]*?)<\/style>/gi);
const styles = styleMatch ? styleMatch.join('\n') : '';
const planHTML = styles + (bodyMatch ? bodyMatch[1] : raw);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>CoWork Prilep — Business Plan</title>
  </head>
  <body>
    <Fragment set:html={planHTML} />
  </body>
</html>
