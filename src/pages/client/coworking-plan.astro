---
export const prerender = false;

import { readFileSync } from 'fs';
import { join } from 'path';

const raw = readFileSync(join(process.cwd(), 'src/private/coworking-plan.html'), 'utf-8');
const bodyMatch = raw.match(/<body[^>]*>([\s\S]*)<\/body>/i);
const styleMatch = raw.match(/<style[^>]*>([\s\S]*?)<\/style>/gi);
const styles = styleMatch ? styleMatch.join('\n') : '';
const planHTML = styles + (bodyMatch ? bodyMatch[1] : raw);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>CoWork Prilep — Business Plan 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Fragment set:html={planHTML} />
  </body>
</html>
