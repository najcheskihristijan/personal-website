---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: "How is SEO different for publishing and media sites?",
    answer: "Publishing SEO is largely about scale and freshness. You're often managing thousands of articles, dealing with cannibalistic content, and competing against much larger domains on high-volume queries. The key levers are content pruning, consolidation, internal linking architecture, and topical authority — not just individual page optimisation."
  },
  {
    question: "What is a content audit and why does publishing need one?",
    answer: "A content audit reviews every page on your site and classifies it as keep, improve, consolidate, or remove. Publishing sites accumulate thin, outdated, and duplicate content over time — this drags down the overall quality signals Google uses to rank the site. A systematic audit followed by action is often the fastest way to recover or grow organic traffic."
  },
  {
    question: "What is programmatic SEO and is it right for publishers?",
    answer: "Programmatic SEO uses templates and structured data to create hundreds or thousands of optimised pages at scale. For publishers with data — stats, comparisons, locations, events — programmatic pages can capture enormous long-tail traffic that would take years to write manually. Done correctly, it's one of the highest-leverage SEO tactics available to publishers."
  },
  {
    question: "How do you build topical authority for a publishing brand?",
    answer: "Topical authority is built by comprehensively covering a subject area — not just writing one article but owning the full topic map. This means pillar pages, supporting articles, internal linking that signals depth, and earning backlinks from authoritative sources within the topic. Over time, Google treats you as a go-to source on that subject."
  }
];
---

<BaseLayout
  title="Fractional SEO Consultant for Publishing & Media | Hristijan Najcheski"
  description="Senior SEO strategy for publishers and media businesses — grow organic sessions, build topical authority, and scale traffic without the agency overhead."
  schemaType="service"
  faqItems={faqItems}
>
  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <span class="section-label">Fractional SEO for Publishing & Media</span>
        <h1>Scale organic traffic <span class="text-gradient">through topical authority</span></h1>
        <p>Senior SEO strategy for content-driven businesses — from content audits and internal linking to programmatic SEO and AI search visibility.</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;margin-top:2rem;">
          <a href="/contact/" class="btn btn-primary btn-lg">Book a Free Strategy Call</a>
          <a href="/pricing/" class="btn btn-secondary btn-lg">View Engagement Models →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="geo-definition">
        <div class="geo-label">What is Fractional SEO for Publishing?</div>
        <p>Fractional SEO for publishing and media is a part-time senior SEO engagement where an expert embeds with your editorial or marketing team to drive organic audience growth. The consultant owns the SEO roadmap — from content architecture and pruning decisions to programmatic page strategies and link building — acting as the strategic SEO lead without the full-time cost.</p>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-bg-secondary);">
    <div class="container">
      <span class="section-label">The Problem</span>
      <h2 class="section-title">Why publishing sites plateau <span class="text-gradient">in organic search</span></h2>
      <div class="pain-grid">
        <div class="pain-card"><div class="pain-icon">📉</div><h3>Content bloat dragging rankings</h3><p class="card-text">Years of publishing create thousands of thin, outdated, and duplicate pages that dilute your overall quality signals — causing even your best content to rank lower than it should.</p></div>
        <div class="pain-card"><div class="pain-icon">🔀</div><h3>Cannibalistic content</h3><p class="card-text">Multiple articles targeting the same keyword split link equity and confuse Google about which page to rank. Without a consolidation strategy, you compete against yourself.</p></div>
        <div class="pain-card"><div class="pain-icon">🏛️</div><h3>Weak topical authority</h3><p class="card-text">Publishing broadly without depth means Google doesn't see you as the authoritative source on any one topic. Depth beats breadth in modern search.</p></div>
        <div class="pain-card"><div class="pain-icon">🤖</div><h3>Missing from AI-generated answers</h3><p class="card-text">As more readers get answers directly from AI tools, publishers not cited by ChatGPT and Perplexity are losing referral traffic. GEO is no longer optional.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="section-label">The Solution</span>
      <h2 class="section-title">What I do for <span class="text-gradient-orange">publishers & media</span></h2>
      <div class="services-grid" style="margin-top:var(--space-10);">
        <div class="card"><div class="card-icon">🔬</div><h3 class="card-title">Content Audit & Pruning</h3><p class="card-text">Systematic review of every page — keep, improve, consolidate, or remove — to lift overall site quality and free up crawl budget for high-value content.</p></div>
        <div class="card"><div class="card-icon">🏛️</div><h3 class="card-title">Topical Authority Strategy</h3><p class="card-text">Topic mapping, pillar content planning, and internal linking architecture that signals depth and expertise to search engines across your core subjects.</p></div>
        <div class="card"><div class="card-icon">⚡</div><h3 class="card-title">Programmatic SEO</h3><p class="card-text">Template-driven pages at scale using your data — statistics, comparisons, locations — capturing long-tail traffic that manual publishing can't reach.</p></div>
        <div class="card"><div class="card-icon">🔗</div><h3 class="card-title">Internal Linking Systems</h3><p class="card-text">Architecting how pages link to each other so link equity flows to your most important content and readers naturally move deeper into your site.</p></div>
        <div class="card"><div class="card-icon">🤖</div><h3 class="card-title">AI Search Visibility (GEO)</h3><p class="card-text">Structuring content with clear definitions, concise answers, and authoritative sourcing so AI tools cite your articles when answering reader questions.</p></div>
        <div class="card"><div class="card-icon">📊</div><h3 class="card-title">Traffic & Revenue Analytics</h3><p class="card-text">Connecting organic traffic to ad revenue, subscriptions, and affiliate income — so every SEO decision is tied to business outcomes.</p></div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--color-bg-secondary);">
    <div class="container">
      <span class="section-label">Results</span>
      <h2 class="section-title">What this looks like <span class="text-gradient">in practice</span></h2>
      <div class="result-card">
        <div class="result-tag">Publishing · Media</div>
        <div class="result-metric">3x organic sessions · 8 months</div>
        <p>Full content audit led to pruning 30% of low-quality pages, consolidating 80+ cannibalising article clusters, and launching a programmatic SEO strategy across the site's data assets. Resulted in 3x organic sessions and #1 rankings for 50+ high-volume industry keywords within 8 months.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="section-label">FAQ</span>
      <h2 class="section-title">Publishing SEO <span class="text-gradient">questions</span></h2>
      <div class="faq-list">
        {faqItems.map((item, i) => (
          <div class="faq-item" id={`faq-${i}`}>
            <button class="faq-question" aria-expanded="false">{item.question}<svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
            <div class="faq-answer">{item.answer}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <script>document.querySelectorAll('.faq-question').forEach((btn)=>{btn.addEventListener('click',()=>{const item=btn.closest('.faq-item') as HTMLElement;const isOpen=item.classList.contains('open');document.querySelectorAll('.faq-item').forEach(el=>{el.classList.remove('open');el.querySelector('.faq-question')?.setAttribute('aria-expanded','false');});if(!isOpen){item.classList.add('open');btn.setAttribute('aria-expanded','true');}});});</script>
  <!-- Related Resources -->
  <section class="section" style="background:var(--color-bg-secondary);"><div class="container"><span class="section-label">Go Deeper</span><h2 class="section-title">Related <span class="text-gradient">resources</span></h2><div class="services-grid" style="margin-top:var(--space-8);"><a href="/services/content-strategy/" class="card" style="text-decoration:none;display:block;"><h3 class="card-title">Content Strategy Services</h3><p class="card-text">Strategic content planning, topic clusters, and editorial calendars built for organic growth.</p><span style="color:var(--color-accent-blue);font-size:0.9rem;">Learn more →</span></a><a href="/blog/content-strategy-eeat/" class="card" style="text-decoration:none;display:block;"><h3 class="card-title">Building E-E-A-T Into Content</h3><p class="card-text">How to demonstrate Experience, Expertise, Authority, and Trust in your content.</p><span style="color:var(--color-accent-blue);font-size:0.9rem;">Read article →</span></a><a href="/blog/why-fractional-seo/" class="card" style="text-decoration:none;display:block;"><h3 class="card-title">Why Fractional SEO Is the Future</h3><p class="card-text">Discover why growing businesses choose fractional SEO consultants over agencies.</p><span style="color:var(--color-accent-blue);font-size:0.9rem;">Read article →</span></a></div></div></section>

  <section class="cta-section"><div class="container"><div class="cta-card"><h2>Ready to grow your audience <span class="text-gradient-orange">through search?</span></h2><p>Let's discuss your content library, current traffic, and what a targeted SEO strategy could unlock.</p><a href="/contact/" class="btn btn-orange btn-lg">Book a Free Strategy Call →</a></div></div></section>

  <style>
    .geo-definition{background:var(--color-bg-elevated);border:1px solid var(--color-accent-blue);border-left:4px solid var(--color-accent-blue);border-radius:var(--radius-xl);padding:var(--space-6) var(--space-8);max-width:860px;margin:0 auto;}
    .geo-label{font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent-blue);margin-bottom:var(--space-3);}
    .geo-definition p{color:var(--color-text-secondary);line-height:1.8;}
    .pain-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--space-6);margin-top:var(--space-10);}
    .pain-card{background:var(--color-bg-elevated);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--space-7);}
    .pain-icon{font-size:2rem;margin-bottom:var(--space-3);}
    .pain-card h3{font-family:var(--font-heading);font-size:var(--text-lg);font-weight:700;color:var(--color-text-primary);margin-bottom:var(--space-2);}
    .result-card{background:var(--color-bg-elevated);border:1px solid var(--color-border);border-radius:var(--radius-2xl);padding:var(--space-10);max-width:760px;margin:var(--space-10) auto 0;}
    .result-tag{font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--color-accent-blue);margin-bottom:var(--space-4);}
    .result-metric{font-family:var(--font-heading);font-size:var(--text-3xl);font-weight:900;color:var(--color-text-primary);margin-bottom:var(--space-4);}
    .result-card p{color:var(--color-text-secondary);line-height:1.8;}
    .faq-list{margin-top:var(--space-10);display:flex;flex-direction:column;gap:var(--space-3);max-width:800px;margin-left:auto;margin-right:auto;}
    .faq-item{background:var(--color-bg-elevated);border:1px solid var(--color-border);border-radius:var(--radius-xl);overflow:hidden;}
    .faq-question{width:100%;display:flex;align-items:center;justify-content:space-between;gap:var(--space-4);padding:var(--space-5) var(--space-6);background:none;border:none;cursor:pointer;text-align:left;font-family:var(--font-heading);font-size:var(--text-base);font-weight:600;color:var(--color-text-primary);}
    .faq-chevron{flex-shrink:0;transition:transform 0.25s ease;color:var(--color-text-muted);}
    .faq-item.open .faq-chevron{transform:rotate(180deg);}
    .faq-answer{display:none;padding:0 var(--space-6) var(--space-5);font-size:var(--text-base);color:var(--color-text-secondary);line-height:1.7;}
    .faq-item.open .faq-answer{display:block;}
    @media(max-width:768px){.pain-grid{grid-template-columns:1fr;}}
  </style>
</BaseLayout>
