---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  {
    question: "Do you charge hourly or on retainer?",
    answer: "Most engagements run on a monthly retainer — this is the model that delivers compounding results over time. For one-off projects like audits or strategy sprints, I work on a fixed-fee basis. I don't charge hourly, as it incentivises the wrong behaviour for both parties."
  },
  {
    question: "What's the minimum engagement length?",
    answer: "Retainer engagements start at 3 months, which is the realistic minimum to see meaningful SEO results. Most clients stay 6–12+ months because the results compound. Audits and strategy sprints are one-time, with no ongoing commitment."
  },
  {
    question: "Can I start with an audit before committing to a retainer?",
    answer: "Absolutely — many clients start with a comprehensive SEO audit to understand the opportunity before committing to an ongoing engagement. If you then move to a retainer, the audit findings become the roadmap."
  },
  {
    question: "Do you work with businesses outside of my country?",
    answer: "Yes. I work with clients globally. All communication happens over video calls, email, and shared documents. Timezone alignment is the only practical consideration — I'm flexible with scheduling."
  },
  {
    question: "How is this different from hiring an agency?",
    answer: "With an agency, your account is managed by a rotating team of juniors overseen by a senior who juggles 20+ accounts. With me, you get direct access to a senior SEO strategist who works as part of your team. No handoffs, no account managers, no upsells."
  }
];
---

<BaseLayout
  title="SEO Consulting Pricing & Engagement Models | Hristijan Najcheski"
  description="Transparent SEO consulting engagement models — monthly retainer, one-time audit, or strategy sprint. Senior-level fractional SEO without the agency overhead."
  schemaType="service"
  faqItems={faqItems}
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <div class="page-header-content">
        <span class="section-label">Pricing & Engagements</span>
        <h1>Senior SEO strategy,<br /><span class="text-gradient">priced to fit your stage</span></h1>
        <p>
          No retainer lock-ins on day one. Start with an audit, scale to a retainer —
          or jump straight in. Every engagement is scoped to your goals.
        </p>
      </div>
    </div>
  </section>

  <!-- Engagement Models -->
  <section class="section">
    <div class="container">
      <span class="section-label">How We Work Together</span>
      <h2 class="section-title">Three ways to <span class="text-gradient">engage</span></h2>
      <p class="section-subtitle">
        Choose the model that fits where you are right now. You can always evolve the engagement as your needs grow.
      </p>

      <div class="pricing-grid">

        <!-- Audit -->
        <div class="pricing-card">
          <div class="pricing-tag">One-Time</div>
          <div class="pricing-icon">🔍</div>
          <h3 class="pricing-title">SEO Audit</h3>
          <p class="pricing-desc">
            A comprehensive deep-dive into your site's technical health, content gaps, and competitive positioning. Delivered as a prioritised action plan your team can execute immediately.
          </p>
          <ul class="pricing-includes">
            <li>Full technical SEO audit</li>
            <li>Content & keyword gap analysis</li>
            <li>Competitor benchmarking</li>
            <li>Prioritised recommendations report</li>
            <li>60-min walkthrough call</li>
          </ul>
          <div class="pricing-footer">
            <div class="pricing-note">Fixed fee · Delivered in 2 weeks</div>
            <a href="/contact/" class="btn btn-secondary">Get a Quote →</a>
          </div>
        </div>

        <!-- Retainer -->
        <div class="pricing-card pricing-card-featured">
          <div class="pricing-tag pricing-tag-featured">Most Popular</div>
          <div class="pricing-icon">📈</div>
          <h3 class="pricing-title">Monthly Retainer</h3>
          <p class="pricing-desc">
            Embedded SEO strategy and execution, month after month. I work as an extension of your team — attending key meetings, owning the SEO roadmap, and reporting directly to you.
          </p>
          <ul class="pricing-includes">
            <li>Full SEO strategy & roadmap</li>
            <li>Technical implementation support</li>
            <li>Content strategy & briefs</li>
            <li>Link building oversight</li>
            <li>Monthly reporting & analytics</li>
            <li>Slack / direct access</li>
          </ul>
          <div class="pricing-footer">
            <div class="pricing-note">Monthly · 3-month minimum</div>
            <a href="/contact/" class="btn btn-primary">Book a Strategy Call →</a>
          </div>
        </div>

        <!-- Sprint -->
        <div class="pricing-card">
          <div class="pricing-tag">Fixed Scope</div>
          <div class="pricing-icon">⚡</div>
          <h3 class="pricing-title">Strategy Sprint</h3>
          <p class="pricing-desc">
            A focused 30-day engagement built around one specific goal — a site migration, a content strategy, a penalty recovery, or a new market launch. Fast, targeted, and actionable.
          </p>
          <ul class="pricing-includes">
            <li>Scoped to one specific challenge</li>
            <li>Dedicated sprint plan & timeline</li>
            <li>Weekly check-in calls</li>
            <li>Full deliverables at close</li>
            <li>Optional retainer handover</li>
          </ul>
          <div class="pricing-footer">
            <div class="pricing-note">Fixed fee · 30-day turnaround</div>
            <a href="/contact/" class="btn btn-secondary">Get a Quote →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section" style="background: var(--color-bg-secondary);">
    <div class="container">
      <span class="section-label">The Process</span>
      <h2 class="section-title">What happens after <span class="text-gradient">you reach out</span></h2>
      <div class="how-grid">
        <div class="how-step">
          <div class="how-number">01</div>
          <h3>Free Strategy Call</h3>
          <p class="card-text">We spend 30 minutes understanding your business, goals, and current SEO situation. No pitch — just an honest conversation about whether and how I can help.</p>
        </div>
        <div class="how-step">
          <div class="how-number">02</div>
          <h3>Scoped Proposal</h3>
          <p class="card-text">I send a clear proposal outlining the engagement model, scope, deliverables, and investment. No boilerplate — every proposal is written specifically for your situation.</p>
        </div>
        <div class="how-step">
          <div class="how-number">03</div>
          <h3>Discovery & Audit</h3>
          <p class="card-text">Once we're aligned, I get to work. Every engagement starts with a thorough audit of your current SEO landscape so the strategy is grounded in real data.</p>
        </div>
        <div class="how-step">
          <div class="how-number">04</div>
          <h3>Execution & Results</h3>
          <p class="card-text">We build, optimise, and iterate. You get regular reporting, clear priorities, and a consultant who is as invested in the results as you are.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <span class="section-label">FAQ</span>
      <h2 class="section-title">Pricing <span class="text-gradient">questions</span></h2>
      <div class="faq-list">
        {faqItems.map((item, i) => (
          <div class="faq-item" id={`faq-${i}`}>
            <button class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
              {item.question}
              <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="faq-answer" id={`faq-answer-${i}`}>
              {item.answer}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item') as HTMLElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach((el) => {
          el.classList.remove('open');
          el.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <h2>Not sure which model <span class="text-gradient-orange">fits you?</span></h2>
        <p>Let's talk. A 30-minute call is all it takes to figure out the right approach for your business.</p>
        <a href="/contact/" class="btn btn-orange btn-lg">Book a Free Strategy Call →</a>
      </div>
    </div>
  </section>

  <style>
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
      margin-top: var(--space-10);
      align-items: start;
    }

    .pricing-card {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-2xl);
      padding: var(--space-8);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      position: relative;
    }

    .pricing-card-featured {
      border-color: var(--color-accent-blue);
      box-shadow: 0 0 0 1px var(--color-accent-blue), var(--shadow-xl);
    }

    .pricing-tag {
      display: inline-block;
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-text-muted);
      background: var(--icon-bg);
      border: 1px solid var(--color-border);
      border-radius: 999px;
      padding: 4px 12px;
      width: fit-content;
    }

    .pricing-tag-featured {
      background: rgba(37, 99, 235, 0.1);
      border-color: rgba(37, 99, 235, 0.3);
      color: var(--color-accent-blue);
    }

    .pricing-icon {
      font-size: 2.5rem;
    }

    .pricing-title {
      font-family: var(--font-heading);
      font-size: var(--text-2xl);
      font-weight: 700;
      color: var(--color-text-primary);
    }

    .pricing-desc {
      font-size: var(--text-base);
      color: var(--color-text-secondary);
      line-height: 1.7;
    }

    .pricing-includes {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      flex: 1;
    }

    .pricing-includes li {
      font-size: var(--text-sm);
      color: var(--color-text-secondary);
      padding-left: var(--space-5);
      position: relative;
    }

    .pricing-includes li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--color-accent-blue);
      font-weight: 700;
    }

    .pricing-footer {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      padding-top: var(--space-4);
      border-top: 1px solid var(--color-border);
    }

    .pricing-note {
      font-size: var(--text-sm);
      color: var(--color-text-muted);
      font-weight: 600;
    }

    .how-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
      margin-top: var(--space-10);
    }

    .how-step {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
    }

    .how-number {
      font-family: var(--font-heading);
      font-size: var(--text-4xl);
      font-weight: 900;
      color: var(--color-accent-blue);
      opacity: 0.3;
      line-height: 1;
      margin-bottom: var(--space-3);
    }

    .how-step h3 {
      font-family: var(--font-heading);
      font-size: var(--text-lg);
      font-weight: 700;
      color: var(--color-text-primary);
      margin-bottom: var(--space-2);
    }

    .faq-list {
      margin-top: var(--space-10);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    .faq-item {
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      overflow: hidden;
    }

    .faq-question {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      padding: var(--space-5) var(--space-6);
      background: none;
      border: none;
      cursor: pointer;
      text-align: left;
      font-family: var(--font-heading);
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--color-text-primary);
    }

    .faq-chevron {
      flex-shrink: 0;
      transition: transform 0.25s ease;
      color: var(--color-text-muted);
    }

    .faq-item.open .faq-chevron { transform: rotate(180deg); }

    .faq-answer {
      display: none;
      padding: 0 var(--space-6) var(--space-5);
      font-size: var(--text-base);
      color: var(--color-text-secondary);
      line-height: 1.7;
    }

    .faq-item.open .faq-answer { display: block; }

    @media (max-width: 1024px) {
      .pricing-grid { grid-template-columns: 1fr; max-width: 520px; margin-left: auto; margin-right: auto; }
      .how-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 640px) {
      .how-grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
