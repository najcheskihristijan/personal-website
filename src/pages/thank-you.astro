---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You — Hristijan Najcheski | Fractional SEO Consultant"
  description="Thank you for reaching out. I'll get back to you within 24 hours."
>
  <section class="thankyou-page">
    <div class="container">
      <div class="thankyou-icon">✅</div>
      <h1>Thank you for <span class="text-gradient">reaching out</span></h1>
      <p>
        Your message has been received! I'll review it and get back to you
        within 24 hours. In the meantime, here are some things you can explore:
      </p>
      <div class="thankyou-actions">
        <a href="/blog/" class="btn btn-primary btn-lg">Read the Blog</a>
        <a href="/services/" class="btn btn-secondary btn-lg">Explore Services →</a>
        <a href="/" class="btn btn-secondary btn-lg">Back to Home</a>
      </div>
    </div>
  </section>
</BaseLayout>
