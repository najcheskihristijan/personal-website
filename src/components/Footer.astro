---
import { services } from '../data/services';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo" style="font-size: 1.5rem;">
          <span class="logo-mark">H</span>N
        </a>
        <p>Helping businesses unlock their organic growth potential through strategic, data-driven SEO consulting.</p>

        <!-- Newsletter signup in footer -->
        <div class="footer-newsletter">
          <p style="color: var(--color-text-primary); font-weight: 600;">Get my free SEO audit checklist</p>
          <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin-bottom: var(--space-3);">Monthly SEO tips for business owners. No fluff, unsubscribe anytime.</p>
          <form class="footer-newsletter-form" id="footerNewsletterForm">
            <input
              type="email"
              class="form-input"
              placeholder="your@email.com"
              required
              id="footerNewsletterEmail"
              name="email"
              aria-label="Email address for newsletter"
            />
            <button type="submit" class="btn btn-primary">Subscribe</button>
          </form>
          <div class="newsletter-success" id="footerNewsletterSuccess">✓ You're subscribed!</div>
          <div class="newsletter-error" id="footerNewsletterError">Something went wrong. Try again.</div>
        </div>

        <!-- Buy Me a Coffee -->
        <div class="footer-bmc">
          <a href="https://www.buymeacoffee.com/najcheski" target="_blank" rel="noopener noreferrer" class="bmc-btn">
            <span class="bmc-icon">☕</span> Buy me a coffee
          </a>
        </div>
      </div>

      <div>
        <h4 class="footer-heading">Navigation</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/services/">Services</a></li>
          <li><a href="/pricing/">Pricing</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="footer-heading">Services</h4>
        <ul class="footer-links">
          {services.map((s) => (
            <li><a href={`/services/${s.slug}/`}>{s.title}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="footer-heading">Get in Touch</h4>
        <ul class="footer-links">
          <li><a href="mailto:najcheski.hristijan@gmail.com">Email Me</a></li>
          <li><a href="/contact/">Contact Page</a></li>
          <li><a href="/author/hristijan-najcheski/">About the Author</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Hristijan Najcheski. All rights reserved. · <a href="/cookie-policy/" style="color: var(--color-text-muted);">Cookie Policy</a></p>
      <div class="social-links">
        <a href="https://www.linkedin.com/in/najcheski/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn" title="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://x.com/HNajcheski" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Twitter/X" title="Twitter/X">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://gravatar.com/najcheski" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Gravatar" title="Gravatar">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<script>
  function initFooterNewsletter() {
    const form = document.getElementById('footerNewsletterForm') as HTMLFormElement;
    const emailInput = document.getElementById('footerNewsletterEmail') as HTMLInputElement;
    const successEl = document.getElementById('footerNewsletterSuccess');
    const errorEl = document.getElementById('footerNewsletterError');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput?.value;
      if (!email) return;

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (res.ok) {
          if (successEl) successEl.style.display = 'block';
          if (errorEl) errorEl.style.display = 'none';
          form.reset();
        } else {
          throw new Error('Failed');
        }
      } catch {
        if (errorEl) errorEl.style.display = 'block';
        if (successEl) successEl.style.display = 'none';
      }
    });
  }

  initFooterNewsletter();
  document.addEventListener('astro:after-swap', initFooterNewsletter);
</script>
