---
import { services } from '../data/services';

export interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Pricing', href: '/pricing/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contact', href: '/contact/' },
];
---

<header class="header" id="header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-mark">H</span>N
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {navItems.slice(0, 2).map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: currentPath === item.href }]}
        >
          {item.label}
        </a>
      ))}

      <!-- Services mega menu -->
      <div class="nav-mega" id="servicesMega">
        <a
          href="/services/"
          class:list={['nav-link', { active: currentPath.startsWith('/services') }]}
          aria-haspopup="true"
          aria-expanded="false"
          id="servicesMegaBtn"
        >
          Services
          <svg class="dropdown-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="mega-menu" role="menu">
          <div class="mega-inner">
            <div class="mega-services">
              <a href="/services/technical-seo/" class="mega-item" role="menuitem">
                <span class="mega-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg></span>
                <div><span class="mega-title">Technical SEO</span><span class="mega-desc">Build a technical foundation search engines love</span></div>
              </a>
              <a href="/services/content-strategy/" class="mega-item" role="menuitem">
                <span class="mega-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></span>
                <div><span class="mega-title">Content Strategy</span><span class="mega-desc">Content that ranks, converts, and compounds</span></div>
              </a>
              <a href="/services/seo-audits/" class="mega-item" role="menuitem">
                <span class="mega-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
                <div><span class="mega-title">SEO Audits</span><span class="mega-desc">Know exactly what's holding your rankings back</span></div>
              </a>
              <a href="/services/link-building/" class="mega-item" role="menuitem">
                <span class="mega-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></span>
                <div><span class="mega-title">Link Building</span><span class="mega-desc">Build authority with links that actually matter</span></div>
              </a>
              <a href="/services/analytics-reporting/" class="mega-item" role="menuitem">
                <span class="mega-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></span>
                <div><span class="mega-title">Analytics & Reporting</span><span class="mega-desc">Turn data into decisions</span></div>
              </a>
              <a href="/services/local-international-seo/" class="mega-item" role="menuitem">
                <span class="mega-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></span>
                <div><span class="mega-title">Local & International SEO</span><span class="mega-desc">Reach your audience wherever they search</span></div>
              </a>
              <a href="/services/ecommerce-seo/" class="mega-item" role="menuitem">
                <span class="mega-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg></span>
                <div><span class="mega-title">E-Commerce SEO</span><span class="mega-desc">Turn organic traffic into e-commerce revenue</span></div>
              </a>
              <a href="/services/seo-migration/" class="mega-item" role="menuitem">
                <span class="mega-icon-wrap"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg></span>
                <div><span class="mega-title">SEO Migration & Relaunch</span><span class="mega-desc">Redesign without losing your rankings</span></div>
              </a>
            </div>
            <div class="mega-sidebar">
              <div class="mega-sidebar-label">Not sure where to start?</div>
              <p class="mega-sidebar-text">Book a free strategy call and I'll help you identify the highest-impact opportunities for your business.</p>
              <a href="/contact/" class="btn btn-primary" style="width:100%;text-align:center;display:block;font-size:0.85rem;">Book a Free Call →</a>
              <a href="/services/" class="mega-all-link">View all services →</a>
            </div>
          </div>
        </div>
      </div>

      {navItems.slice(2).map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: currentPath === item.href }]}
        >
          {item.label}
        </a>
      ))}

      <span class="nav-social-proof">50+ projects delivered</span>
      <a href="/contact/" class="btn btn-primary nav-cta">Get in Touch</a>
    </nav>

    <div style="display: flex; align-items: center; gap: 0;">
      <Fragment>
        <button
          class="theme-toggle"
          id="themeToggle"
          aria-label="Toggle dark mode"
          title="Toggle dark mode"
        >
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
        </button>
      </Fragment>

      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Toggle menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav" id="mobileNav">
  <a href="/">Home</a>
  <a href="/about/">About</a>
  <div class="mobile-nav-services">
    <a href="/services/" class="mobile-nav-services-heading">Services</a>
    <div class="mobile-nav-services-list">
      {services.map((s) => (
        <a href={`/services/${s.slug}/`} class="mobile-nav-service-item">
          <span>{s.icon}</span> {s.title}
        </a>
      ))}
    </div>
  </div>
  <a href="/blog/">Blog</a>
  <a href="/contact/">Contact</a>
  <a href="/contact/" class="btn btn-primary" style="margin-top: auto; text-align: center;">
    Get in Touch
  </a>
</div>

<style>
  /* Mega menu wrapper */
  .nav-mega {
    position: static;
  }

  .dropdown-chevron {
    display: inline-block;
    margin-left: 3px;
    vertical-align: middle;
    transition: transform 250ms ease;
  }

  .nav-mega:hover .dropdown-chevron,
  .nav-mega.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  /* Mega menu panel */
  .mega-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-bg-primary);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 200ms ease, transform 200ms ease, visibility 200ms;
    z-index: 999;
  }

  .nav-mega:hover .mega-menu,
  .nav-mega.open .mega-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .mega-inner {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-6);
  }

  .mega-services {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
  }

  .mega-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: background 150ms ease;
  }

  .mega-item:hover {
    background: var(--color-bg-secondary);
  }

  .mega-icon-wrap {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    flex-shrink: 0;
    color: var(--color-accent-blue);
    transition: background 150ms ease, border-color 150ms ease;
  }

  .mega-item:hover .mega-icon-wrap {
    background: var(--color-accent-blue);
    border-color: var(--color-accent-blue);
    color: #fff;
  }

  .mega-title {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .mega-desc {
    display: block;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-top: 2px;
  }

  .mega-sidebar {
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
  }

  .mega-sidebar-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .mega-sidebar-text {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .mega-all-link {
    font-size: 0.8rem;
    color: var(--color-accent-blue);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 150ms;
  }

  .mega-all-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .mega-menu {
      display: none;
    }
  }

  /* Mobile services */
  .mobile-nav-services {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .mobile-nav-services-heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .mobile-nav-services-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-left: var(--space-4);
  }

  .mobile-nav-service-item {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    transition: color var(--transition-fast);
  }

  .mobile-nav-service-item:hover {
    color: var(--color-text-primary);
  }
</style>

<script>
  function initTheme() {
    const toggle = document.getElementById('themeToggle');
    const stored = localStorage.getItem('theme');

    if (stored === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    } else if (stored === 'light') {
      document.documentElement.removeAttribute('data-theme');
    } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }

    toggle?.addEventListener('click', () => {
      document.documentElement.classList.add('theme-transition');
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      if (next === 'light') {
        document.documentElement.removeAttribute('data-theme');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
      localStorage.setItem('theme', next);
      setTimeout(() => {
        document.documentElement.classList.remove('theme-transition');
      }, 350);
    });
  }

  function initMobileMenu() {
    const btn = document.getElementById('mobileMenuBtn');
    const nav = document.getElementById('mobileNav');

    btn?.addEventListener('click', () => {
      const isOpen = nav?.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    nav?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        nav.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }

  initTheme();
  initMobileMenu();
  document.addEventListener('astro:after-swap', () => {
    initTheme();
    initMobileMenu();
  });
</script>
